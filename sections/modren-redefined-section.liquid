<style>
      .section-{{ section.id }}-padding {
            padding-top: {{ section.settings.padding_top }}px;
          padding-bottom: {{ section.settings.padding_bottom }}px;
          padding-left: {{ section.settings.padding_left }}px;
          padding-right: {{ section.settings.padding_right }}px;
          background-color: {{ section.settings.back-color}};
      }

      .mod-main-feature-section{
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 40px;
      position: relative;
      }
      .mod-main-head p {
      color: #000;
      font-family: "League Spartan";
      font-size: 36px;
      font-style: normal;
      font-weight: 600;
      line-height: 36px;
      text-transform: uppercase;
      max-width: 500px;
  }
  .mod-main-desc p {
      color: var(--Black, #171717);
      font-family: Quicksand;
      font-size: 16px;
      font-style: normal;
      font-weight: 400;
      line-height: normal;
      max-width: 500px;
  }
      img.cs_mod_img {
         width: 565px;
      height: 535px;
      aspect-ratio: 138 / 139;
      display: block;
  }
      .rating-icon img {
          display: flex;
      }
      .mod-content-left {
          width: 50%;
        display: flex;
    flex-direction: column;
    gap: 8px;
      }
      .mod-b-right {
          width: 50%;
      }
      .produt-feature-section-main-desc p{
          color: var(--Black, #171717);
    font-family: Quicksand;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    padding-bottom:20px;
    line-height: normal;
        max-width: 620px;
      }
      .product-feature-section-main-heading p{
          color: var(--Black, #171717);
    font-family: "League Spartan";
    font-size: 36px;
    font-style: normal;
    font-weight: 600;
    line-height: 36px; /* 100% */
    text-transform: uppercase;
    padding-bottom:8px;
      }
      .pro-feature-img-main{
        display:block;
        border-radius: 20px;
      }
        .home-feature-product {
          display: flex;
          background: #f0f3ff; /* Light background */
          border-radius: 12px;
          padding: 25px;
          /* max-width: 420px; */
          align-items: center;
        }
        .bottle-images {
          background: #c3c6cc;
          border-radius: 12px;
          margin-right: 20px;
          width: 200px;
          /* height: 200px; */
        }
        .main-product-img img {
          width: 100%;
          height: 100%;
          object-fit: contain;
          border-radius: 12px;
        }
        .product-details h3 {
          margin: 0 0 12px 0;
          color: var(--DARK-GREY, #333232);
          font-family: Satoshi;
          font-size: 20px;
          font-style: normal;
          font-weight: 500;
          line-height: normal;
          text-transform: capitalize;
        }
        .wrinkle-price-container{
          margin-bottom: 28px;
        }
        .wrinkle-compare-price {
          text-decoration: line-through;
          margin-right: 8px;
          color: #A9A9A9;
          text-align: right;
          font-family: Satoshi;
          font-size: 16px;
          font-style: normal;
          font-weight: 500;
          line-height: 18px;
        }
        .wrinkle-product-price {
          color: #3B3B3B;
          text-align: right;
          font-family: Satoshi;
          font-size: 16px;
          font-style: normal;
          font-weight: 500;
          line-height: 18px;
        }
        .discount-price {
          margin-left: 12px;
          font-weight: 700;
          color: #5e47ff;
        }
       .wrinkle-cart-btn  {
          background: #3f4fff;
          border: none;
          padding: 16px 0;
          border-radius: 25px;
          width: 100%;
          cursor: pointer;
          color: #FFF;
          text-align: center;
          font-family: Satoshi;
          font-size: 16px;
          font-style: normal;
          font-weight: 700;
          line-height: 22px;
          text-transform: uppercase;
        }
        .star-rating {
          margin-bottom: 12px;
          display: flex;
          gap: 6px;
          align-items: center;
          color: #3B3B3B;
          text-align: right;
          font-family: Satoshi;
          font-size: 16px;
          font-style: normal;
          font-weight: 400;
          line-height: 18px;
        }
      .image-play-icon-vid {
          position: absolute;
          top: 50%;
          max-width: 50px;
          max-height: 50px;
          left: 50%;
          transform: translate(-50%, -50%) !important;
      }
      .video-wrapper-feature {
          position: relative;
      }
      .feature-vid{
        width:100%;
      }
      .video-wrapper-feature video {
          {% comment %} border-radius: 20px; {% endcomment %}
           display:block;
      }
      .mod-list-icon-main {
        display: flex;
        /* justify-content: center; */
        align-items: center;
        gap: 16px;
    }
    .mod-img {
      position: absolute;
      top: 43%;
      left: 47%;
      transform: translate(-50%, -50%);
  }
    .mods-feature-lists {
        border: 0.6px solid var(--teal, #00727F);
        background: rgba(140, 156, 110, 0.15);
        display: flex;
        padding: 54px 44px;
      flex-direction: column;
      align-items: center;
        gap: 24px;
        align-self: stretch;
        {% comment %} max-width: 620px; {% endcomment %}
    }
    .mod-list-heading p {
        color: var(--Black, #171717);
        /* text-align: center; */
        font-family: "League Spartan";
        font-size: 20px;
        font-style: normal;
        font-weight: 500;
        line-height: normal;
        text-transform: capitalize;
    }
    .mod-list-desc {
        color: var(--Black, #171717);
        font-family: Quicksand;
        font-size: 14px;
        font-style: normal;
        font-weight: 500;
        line-height: 20px;
            max-width: 324px;
    }
    .mod-features-content {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .mod-list-icon img {
        width: 40px;
        height: 40px;
        display: block;
    }
      @media screen and (max-width: 768px){
      .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.mbl_padding_top }}px;
          padding-bottom: {{ section.settings.mbl_padding_bottom}}px;
          padding-left: {{ section.settings.mbl_padding_left }}px;
          padding-right: {{ section.settings.mbl_padding_right}}px;
      }
        .bottle-images{
          margin-right: 12px;
        }
        .mod-content-left{
        {% comment %} display:none; {% endcomment %}
        }
        .mods-feature-lists{
      padding: 80px 15px 41px;
        margin: 0 10px;
        gap:24px;
    }
    .mod-main-head p{
  font-size: 27px;
  font-style: normal;
  font-weight: 600;
  line-height: normal;
  }
      .mod-content-left {
          width: 100%;
          display: flex;
          flex-direction: column;
          gap: 12px;
      }
      .mod-b-right {
          width: 100%;
      }
       .mod-main-feature-section{
      flex-direction: column;
      gap: 220px;
       }
      .product-feature-section-main-heading p{
        font-size: 28px;
        text-align: center;
            padding-bottom: 12px;
      }
      .mod-img{
          width: 100%;
          top: 47%;
      }
      img.cs_mod_img{
      height: inherit;
      }
      .produt-feature-section-main-desc p{
        text-align:center;
            padding-bottom: 24px;
      }
      .rating-icon img{
        width:56px;
      }
      .home-feature-product{
        padding:15px;
      }
      .rating-num{
        font-size: 12px;
        line-height: 11.207px;
      }
      .product-details h3{
        font-size: 14px;
        margin-bottom: 7px;
      }
      .wrinkle-product-price{
        font-size: 12px;
        line-height: 11.207px;
      }
      .wrinkle-compare-price{
        font-size: 12px;
        line-height: 11.207px;
      }
      .star-rating{
        margin-bottom:7px;
        gap:3px;
      }
      .wrinkle-price-container{
            margin-bottom: 17px;
      }
      .wrinkle-cart-btn {
        font-size: 12px;
        line-height: 13.697px;
        /* padding: 9px 37px; */
      }



        }
</style>

<section class="section-{{ section.id }}-padding bounce-up fade-up">
  <div class="page-width">
    <div class="mod-main-feature-section">
      <div class="mod-content-left">
        <div class="mod-main-head">{{ section.settings.mod_main_heading }}</div>
        <div class="mod-main-desc">{{ section.settings.mod_main_desc }}</div>

        <div class="mod-img">
          {{
            section.settings.banner_iamge
            | image_url: width: 1440
            | image_tag:
              widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
              class: 'cs_mod_img',
              alt: 'image',
              loading: 'eager'
          }}
        </div>
      </div>
      <div class="mod-b-right">
        <div class="mods-feature-lists">
          {% for block in section.blocks %}
            <div class="mod-list-icon-main">
              <div class="mod-list-icon">
                {{
                  block.settings.image
                  | image_url: width: 1440
                  | image_tag:
                    widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                    class: 'cs_mod_icon',
                    alt: 'image',
                    loading: 'eager'
                }}
              </div>
              <div class="mod-features-content">
                <div class="mod-list-heading">{{ block.settings['features-heading'] }}</div>
                <div class="mod-list-desc">{{ block.settings['features-description'] }}</div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Modren Design",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding left",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Right",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Left Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Right Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back-color",
      "label": "Background Color"
    },
    {
      "type": "richtext",
      "id": "mod_main_heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "mod_main_desc",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "banner_iamge",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "type": "blocks",
      "name": "Add Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "features-heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "features-description",
          "label": "Features Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modren Design"
    }
  ]
}
{% endschema %}
