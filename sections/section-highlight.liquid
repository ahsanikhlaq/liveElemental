{%- liquid
  assign unique = section.id
  assign animation_anchor = '#highlights--' | append: unique
  assign heading = section.settings.heading
  assign heading_size_class = section.settings.heading_size | plus: 0 | prepend: 'heading-size-'
  assign font_size_class = section.settings.text_size | plus: 0 | prepend: 'body-size-'
  assign text_color = section.settings.color
  assign bg_color = section.settings.bg_color
  assign blocks_style = section.settings.style

  assign columns_desktop = section.settings.grid | plus: 0
  assign columns_mobile = section.settings.layout_mobile | plus: 0
  assign columns_tablet = 3
  assign columns_small = 2

  assign heading_plain = heading | strip_html | strip
  assign heading_id = 'highlights-heading-' | append: unique

  capture items_classes
    echo 'highlights__items'
    if section.settings.layout_mobile == 'carousel'
      echo ' highlights__items--mobile-slider'
    else
      echo ' highlights__items--mobile-grid'
    endif
  endcapture
-%}

{%- style -%}
  #highlights--{{ unique }} {
    --PT: {{ section.settings.padding_top }}px;
    --PB: {{ section.settings.padding_bottom }}px;

    {% if text_color != blank and text_color != 'rgba(0,0,0,0)' %}
      --text: {{ text_color }};
    {% endif %}
    {% if bg_color != blank and bg_color != 'rgba(0,0,0,0)' %}
      --bg: {{ bg_color }};
    {% endif %}

    --columns-desktop: {{ columns_desktop }};
    --columns-tablet: {{ columns_tablet }};
    --columns-small: {{ columns_small }};
    --columns-mobile: {{ columns_mobile }};
  }

  .highlights__items {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr;
    gap: 20px;
    padding: 20px 91px;
    list-style: none;
    margin: 0;
  }
  h2.highlights__title {
    color: #000;
    text-align: center;
    font-family: "League Spartan";
    font-size: 36px;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
  }

  .highlights__item-link:focus-visible,
  .highlights__item-inner:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
  .highlights__item-inner.is-disabled {
    cursor: not-allowed;
    opacity: 0.6;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-aos] {
      transition: none !important;
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (max-width: 786px) {
    .highlights__items {
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      padding: 10px 10px;
    }
    h2.highlights__title { font-size: 28px; }
  }
{%- endstyle -%}

<section
  class="highlights section-padding"
  id="highlights--{{ unique }}"
  data-section-id="{{ unique }}"
  data-section-type="highlights"
  {% if heading_plain != blank %}
    aria-labelledby="{{ heading_id }}"
  {% else %}
    aria-label="Highlights"
  {% endif %}
>
  <div class="{{ section.settings.width }} highlights__container">

    {%- if heading != blank -%}
      <div class="grid__heading-holder {{ section.settings.heading_position }}">
        <h2
          id="{{ heading_id }}"
          class="highlights__title grid__heading {{ heading_size_class }}"
          data-aos="hero"
          data-aos-anchor="{{ animation_anchor }}"
          data-aos-order="1"
        >
          {{- heading | escape -}}
        </h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="{{ items_classes }}" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign image = block.settings.image
            assign bg_color = block.settings.bg_color
            assign text_color = block.settings.color
            assign border_color = block.settings.border_color

            assign bg_color_brightness = bg_color | color_brightness
            if bg_color_brightness <= 65
              assign bg_color_brighter = bg_color | color_lighten: 10
            else
              assign bg_color_brighter = bg_color | color_darken: 5
            endif

            assign border_color_brightness = border_color | color_brightness
            if border_color_brightness <= 65
              assign border_color_brighter = border_color | color_lighten: 10
            else
              assign border_color_brighter = border_color | color_darken: 5
            endif

            assign link = block.settings.url
            assign block_heading = block.settings.heading | strip
            if block_heading == blank
              assign block_heading = 'Highlight ' | append: forloop.index
            endif

            # alt text priority: customizer field → image library alt → block heading
            assign custom_alt = block.settings.image_alt | strip
            if custom_alt != blank
              assign image_alt = custom_alt
            elsif image.alt != blank
              assign image_alt = image.alt
            else
              assign image_alt = block_heading
            endif

            assign animation_delay = forloop.index0 | times: 150

            assign has_bg_color = false
            if bg_color != 'rgba(0,0,0,0)' and bg_color != blank
              assign has_bg_color = true
            endif
            assign has_text_color = false
            if text_color != 'rgba(0,0,0,0)' and text_color != blank
              assign has_text_color = true
            endif
            assign has_border_color = false
            if border_color != 'rgba(0,0,0,0)' and border_color != blank
              assign has_border_color = true
            endif

            capture aos
              echo 'data-aos="fade"'
              echo 'data-aos-duration="500"'
              echo 'data-aos-delay="' | append: animation_delay | append: '"'
              echo 'data-aos-anchor="' | append: animation_anchor | append: '"'
            endcapture

            capture style
              if has_text_color or has_bg_color or has_border_color
                echo 'style="'
                if has_bg_color
                  echo '--bg: ' | append: bg_color | append: ';'
                  echo '--bg-brighter: ' | append: bg_color_brighter | append: ';'
                endif
                if has_text_color
                  echo '--text: ' | append: text_color | append: ';'
                endif
                if has_border_color
                  echo '--border: ' | append: border_color | append: ';'
                  echo '--border-brighter: ' | append: border_color_brighter | append: ';'
                endif
                echo '"'
              endif
            endcapture

            capture item_attributes
              echo 'class="highlights__item highlights__item--' | append: blocks_style
              echo '"'
              echo aos | append: ' ' | append: style | append: ' ' | append: block.shopify_attributes
            endcapture

            capture item_inner_classes
              echo 'highlights__item-inner'
              if blocks_style == 'button'
                echo ' btn btn--outline btn--large'
                unless link != blank
                  echo ' is-disabled'
                endunless
              elsif link != blank
                echo ' highlights__item-link'
              endif
            endcapture
          -%}

          <li {{ item_attributes }}>
            {%- if link != blank -%}
              <a
                href="{{ link }}"
                class="{{ item_inner_classes }}"
                aria-label="{{ block_heading | escape }}"
                {% if link == request.path %}aria-current="page"{% endif %}
              >
            {%- else -%}
              <span
                class="{{ item_inner_classes }}"
                aria-label="{{ block_heading | escape }}"
              >
            {%- endif -%}

              {%- if image or blocks_style != 'button' -%}
                <div class="highlights__item__background">
                  {%- if image -%}
                    <img
                      src="{{ image | image_url: width: 800 }}"
                      srcset="
                        {{ image | image_url: width: 200 }} 200w,
                        {{ image | image_url: width: 400 }} 400w,
                        {{ image | image_url: width: 600 }} 600w,
                        {{ image | image_url: width: 800 }} 800w,
                        {{ image | image_url: width: 1000 }} 1000w
                      "
                      sizes="(min-width: 990px) calc((100vw - 100px) / {{ columns_desktop }}), (min-width: 750px) calc((100vw - 60px) / {{ columns_tablet }}), calc(100vw - 32px)"
                      width="{{ image.width }}"
                      height="{{ image.height }}"
                      alt="{{ image_alt | escape }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                </div>
              {%- endif -%}

              <div class="highlights__item__content {{ font_size_class }}">
                <span>{{ block_heading | escape }}</span>
              </div>

            {%- if link != blank -%}
              </a>
            {%- else -%}
              </span>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Highlights",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "style", "label": "Style",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "rectangle", "label": "Rectangle" },
        { "value": "circle", "label": "Circle" },
        { "value": "button", "label": "Button" }
      ],
      "default": "rectangle"
    },
    { "type": "range", "id": "grid", "min": 3, "max": 8, "step": 1, "label": "Highlights per row", "default": 6 },
    { "type": "header", "content": "Style" },
    {
      "type": "select", "id": "width", "label": "Width", "default": "wrapper--full-padded",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--narrow", "label": "Narrow" }
      ]
    },
    { "type": "header", "content": "Text" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Highlights" },
    {
      "type": "select", "id": "heading_position", "label": "Heading position",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" }
      ],
      "default": "text-center"
    },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 1, "max": 15, "step": 1, "default": 8 },
    { "type": "range", "id": "text_size", "label": "Text size", "min": 1, "max": 15, "step": 1, "default": 3 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "color", "label": "Text" },
    { "type": "color", "id": "bg_color", "label": "Background" },
    { "type": "header", "content": "Mobile" },
    {
      "type": "select", "id": "layout_mobile", "label": "Layout",
      "options": [
        { "value": "1", "label": "1 highlight per row" },
        { "value": "2", "label": "2 highlights per row" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "2"
    },
    { "type": "header", "content": "Section padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Padding top", "default": 50 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 1, "unit": "px", "label": "Padding bottom", "default": 50 }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Highlight" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "header", "content": "Background" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "info": "Describe what the image shows for screen readers and accessibility audits. Leave blank to fall back to the heading."
        },
        { "type": "header", "content": "Colors" },
        { "type": "color", "id": "color", "label": "Text" },
        { "type": "color", "id": "bg_color", "label": "Background", "default": "#F0F0F0" },
        { "type": "color", "id": "border_color", "label": "Border" }
      ]
    }
  ],
  "presets": [
    {
      "category": "Text",
      "name": "Highlights",
      "blocks": [
        { "type": "highlight", "settings": { "heading": "Tops" } },
        { "type": "highlight", "settings": { "heading": "Bottoms" } },
        { "type": "highlight", "settings": { "heading": "Dresses" } },
        { "type": "highlight", "settings": { "heading": "Socks" } },
        { "type": "highlight", "settings": { "heading": "Sales" } },
        { "type": "highlight", "settings": { "heading": "New Arrivals" } }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "custom.pre_footer"]
  }
}
{% endschema %}