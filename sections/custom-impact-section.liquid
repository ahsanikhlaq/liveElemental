<style>
  .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.back_color }};
      position: relative;
  }
  .imp-wrap{
   {% comment %} padding: 157px 82.426px 157.936px 83px; {% endcomment %}
  padding: 57px 82.426px 57.936px 83px;
  }
  .imp-defusr-wrap{
   padding: 120px 82.426px 120px 83px;
  }
  .im-es-content h4 {
      text-align: left;
      color: var(--White, #FFF);
      font-family: "League Spartan";
      font-size: 40px;
      font-style: normal;
      font-weight: 500;
      line-height: normal;
      padding: 0 0 30px;
      margin: 0;
  }

  .imp-btm-text{
  color: var(--White, #FFF);
  font-family: Quicksand;
  font-size: 16px;
  font-style: normal;
  font-weight: 500;
  line-height: 22px;
  max-width:400px;
  }
  .impact-tabs-wrapper {
      display: flex;
      gap: 40px;
      position: relative;
      z-index: 1;
      justify-content: space-between;
  }
  .im-es-content p{
      color: var(--White, #FFF);
      font-family: Quicksand;
      font-size: 18px;
      font-style: normal;
      font-weight: 500;
      line-height: 22px;
      max-width: 550px;
  }
  .im-head-content{
      color: #FFFFFF;
      font-family: "League Spartan";
      font-size: 36px;
      font-style: normal;
      font-weight: 600;
      line-height: normal;
      text-transform: uppercase;
      text-align: left;
      padding-bottom: 25px;
  }
  .impact-tabs-left {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
  }

  .impact-tabs-list {
  }

  .impact-tab-label {
      color: {{ section.settings.tab_text_color }};
      font-size: {{ section.settings.tab_font_size }}px;
      font-weight: {{ section.settings.tab_font_weight }};
      margin-bottom: 24px;
      font-family: "League Spartan";
      text-transform: uppercase;
      letter-spacing: 0;
      transition: all 0.3s ease;
  }

  .impact-tab-button {
      display: block;
      width: 100%;
      text-align: left;
      background: none;
      border: none;
      color: var(--White, #FFF);
      font-family: "League Spartan";
      font-size: 40px;
      font-style: normal;
      font-weight: 500;
      line-height: normal;
      padding: 0 0 16px;
      cursor: pointer;
      transition: all 0.3s ease;
      opacity: 0.5;
  }

  .impact-tab-button:hover {
      opacity: 0.8;
  }

  .impact-tab-button.active {
      opacity: 1;
      color: {{ section.settings.active_tab_color }};
  }

  .impact-tabs-right {
      position: relative;
  }

  .impact-tab-content {
      display: none;
      animation: fadeIn 0.5s ease;
  }

  .impact-tab-content.active {
      display: block;
  }

  .impact-tab-content img {
      height: auto;
      width:100%;
      max-width: 568px;
      min-height: 404px;
  }

  @keyframes fadeIn {
      from {
          opacity: 0;
          transform: translateY(10px);
      }
      to {
          opacity: 1;
          transform: translateY(0);
      }
  }
  .content_image{
  display:block;
  }
  .content_image_mbl{
  display:none;
  }
  .mbl-righ-txt{
  display:none;
  }
  @media screen and (max-width: 768px) {
      .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.mbl_padding_top }}px;
          padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
          {% if section.settings.show_background_on_mobile == false %}
          background-image: none !important;
          {% endif %}
      }
      .impact-tab-button.active{
      color: var(--Black, #171717);
      }
      .mbl-righ-txt{
  display:block;
  color: var(--Black, #171717);
  text-align: center;

  /* Body/Medium/14 */
  font-family: Quicksand;
  font-size: 14px;
  font-style: normal;
  font-weight: 500;
  line-height: 20px; /* 142.857% */
  }
      .content_image{
  display:none;
  }
  .content_image_mbl{
  display:block;
  }
  .imp-wrap {
  padding:0;
  }
  .imp-defusr-wrap{
   padding: 0;
  }
  .impact-tab-label{
  {% comment %} display:none; {% endcomment %}
  padding-left: 10px;
  }
      .impact-tab-content{
      padding: 16px 10px;
      }

      .impact-tabs-wrapper {
          flex-direction: column-reverse;
          gap: 0;
      }

      .impact-tabs-left {
          order: 2;
          margin-top: 20px;
          padding: 0 10px;
      }

      .impact-tabs-right {
          order: 1;
          width: 100%;
      }

      .impact-tabs-list {
          display: flex;
          gap: 10px;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          padding-bottom: 14px;
      }

      .impact-tabs-list::-webkit-scrollbar {
          display: none;
      }

      .impact-tab-button {
          font-size: {{ section.settings.mbl_tab_button_size }}px;
          padding: 0;
          white-space: nowrap;
          {% comment %} flex-shrink: 0; {% endcomment %}
           color: var(--Grey, #797979);
      }

      .impact-tab-content img {
          max-width: 100%;
          min-height: unset;
          {% comment %} border-radius: 8px; {% endcomment %}
      }

      .imp-btm-text {
         color: var(--Black, #171717);
          font-size: 14px;
          font-style: normal;
          font-weight: 500;
          line-height: 20px;
          {% comment %} margin-top: 16px; {% endcomment %}
      }
      .im-es-content h4{
      font-size: 33px;
      }
  }
</style>

<section
  class="section-{{ section.id }}-padding"
  {% if section.settings.background_image != blank %}
    style="background-image: url('{{ section.settings.background_image | img_url: 'master' }}'); background-size: cover; background-position: center; background-repeat: no-repeat;"
  {% endif %}
>
  <div class="page-width">
    <div class="{% if template.suffix == 'car-deffuser' %}imp-defusr-wrap{% else %}imp-wrap{% endif %}">
      <p class="impact-tab-label" id="dynamic-tab-label">{{ section.settings.tab_label }}</p>
      <div class="impact-tabs-wrapper">
        <!-- Left Side: Tabs -->
        <div class="impact-tabs-left">
            <div class="impact-tabs-list">
              {% for block in section.blocks %}
                <button
                  class="impact-tab-button {% if forloop.first %}active{% endif %}"
                  data-tab="tab-{{ block.id }}"
                  data-label="{{ block.settings.tab_label_text }}"
                  data-bottom-text="{{ block.settings.tab_bottom_text }}"
                  type="button"
                >
                  {{ block.settings.tab_title }}
                </button>
              {% endfor %}
            </div>
          <div class="imp-btm-text" id="dynamic-bottom-text">
            {% if section.blocks.first.settings.tab_bottom_text != blank %}
              {{ section.blocks.first.settings.tab_bottom_text }}
            {% else %}
              {{ section.settings['imp-bottom-txt'] }}
            {% endif %}
          </div>

          {% if section.settings.imp_main_desc != blank %}
            <div class="imp-main-des">
              {% if section.settings.imp_main_head != blank %}
                <div class="im-head-content">{{ section.settings.imp_main_head }}</div>
              {% endif %}
              <div class="im-es-content">{{ section.settings.imp_main_desc }}</div>
            </div>
          {% endif %}
        </div>

        <!-- Right Side: Tab Content -->
        <div class="impact-tabs-right">
          <div class="imp-rigt-wrap">
            {% for block in section.blocks %}
              <div
                class="impact-tab-content {% if forloop.first %}active{% endif %}"
                id="tab-{{ block.id }}"
              >
                {% if block.settings.content_image != blank %}
                  <img
                    class="content_image"
                    src="{{ block.settings.content_image | img_url: '' }}"
                    alt="{{ block.settings.tab_title }}"
                    width="100%"
                    height="100%"
                  >
                {% endif %}
                {% if block.settings.content_image_mbl != blank %}
                  <img
                    class="content_image_mbl"
                    src="{{ block.settings.content_image_mbl | img_url: '' }}"
                    alt="{{ block.settings.tab_title }}"
                    width="100%"
                    height="100%"
                  >
                {% endif %}
              </div>
            {% endfor %}
          </div>
          <div class="mbl-righ-txt">{{ section.settings['mbl-right-txt'] }}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const tabButtons = document.querySelectorAll('.impact-tab-button');
    const dynamicLabel = document.getElementById('dynamic-tab-label');
    const dynamicBottomText = document.getElementById('dynamic-bottom-text');

    tabButtons.forEach((button) => {
      // Hover event for desktop
      button.addEventListener('mouseenter', function () {
        // Only trigger hover on desktop (screen width > 768px)
        if (window.innerWidth > 768) {
          const targetTab = this.getAttribute('data-tab');
          const labelText = this.getAttribute('data-label');
          const bottomText = this.getAttribute('data-bottom-text');

          // Update the label text
          if (labelText && dynamicLabel) {
            dynamicLabel.textContent = labelText;
          }

          // Update the bottom text
          if (bottomText && dynamicBottomText) {
            dynamicBottomText.textContent = bottomText;
          }

          // Remove active class from all buttons
          tabButtons.forEach((btn) => btn.classList.remove('active'));

          // Add active class to hovered button
          this.classList.add('active');

          // Hide all tab contents
          document.querySelectorAll('.impact-tab-content').forEach((content) => {
            content.classList.remove('active');
          });

          // Show target tab content
          document.getElementById(targetTab).classList.add('active');
        }
      });

      // Click event for mobile
      button.addEventListener('click', function () {
        // Only trigger click on mobile (screen width <= 768px)
        if (window.innerWidth <= 768) {
          const targetTab = this.getAttribute('data-tab');
          const labelText = this.getAttribute('data-label');
          const bottomText = this.getAttribute('data-bottom-text');

          // Update the label text
          if (labelText && dynamicLabel) {
            dynamicLabel.textContent = labelText;
          }

          // Update the bottom text
          if (bottomText && dynamicBottomText) {
            dynamicBottomText.textContent = bottomText;
          }

          // Remove active class from all buttons
          tabButtons.forEach((btn) => btn.classList.remove('active'));

          // Add active class to clicked button
          this.classList.add('active');

          // Hide all tab contents
          document.querySelectorAll('.impact-tab-content').forEach((content) => {
            content.classList.remove('active');
          });

          // Show target tab content
          document.getElementById(targetTab).classList.add('active');

          // Scroll active button into view on mobile
          this.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
      });
    });
  });
</script>

