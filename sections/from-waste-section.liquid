<style>
  .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.back_color }};
  }
.fm_waste_container {
    {% comment %} display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 16px; {% endcomment %}
}
.fm-head {
    color: #000;
    font-family: "League Spartan";
    font-size: 36px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
}
.fm-desc {
    color: var(--Black, #171717);
    font-family: Quicksand;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
}
.fm-wst-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 10px;
}
.process-icon-ab img {
    width: 60px;
    height: 60px;
    display: block;
    margin-bottom: 20px;
}
.process-step-ab {
    border: 1px solid var(--almond-forest, #8C7A6E);
    background: rgba(140, 156, 110, 0.05);
    display: flex;
    padding: 5px 12px 3px 12px;
    justify-content: center;
    align-items: center;
    color: var(--almond-forest, #8C7A6E);
    text-align: center;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    font-family: Quicksand;
    line-height: normal;
    max-width: 72px;
    margin: 0 auto 16px;
}
.process-title-ab {
    color: var(--Black, #171717);
    text-align: center;
    font-family: "League Spartan";
    font-size: 20px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    text-transform: capitalize;
    margin: 0;
}
.process-desc-ab {
    color: var(--Black, #171717);
    text-align: center;
    font-family: Quicksand;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 20px;
    margin: 0;
    max-width: 208px;
    padding-top: 4px;
}
.process-card-ab {
    border-radius: 1px;
    transition: all 0.3s ease-in-out; /* Smooth transition for the hover effect */
    background: #F7F7F7;
    display: flex;
    padding: 16px 12px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    {% comment %} gap: 20px; {% endcomment %}
}
.process-card-ab:hover {
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Adds a subtle shadow */
  transform: translateY(-5px); /* Moves the card up slightly */
}
.fm-wast-block {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
    padding: 16px 20px 0;
}
  @media screen and (max-width:768px){
  .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.mbl_padding_top }}px;
      padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
    }
.fm-wast-block {
    grid-template-columns: 1fr;
    gap: 12px;
    padding: 16px 10px 0;
}
.process-icon-ab img {
    margin: 0;
    width: 38px;
height: 38px;
}
.fm-desc{
max-width: 353px;
}
.process-step-ab{
font-size: 12px;
padding: 6px 12px 4px 12px;
margin: 0 0 12px;
max-width: 65px;
}
.process-card-ab{
flex-direction: row;
justify-content: normal;
gap: 12px;
}
.process-title-ab {
  text-align: unset;
  font-size: 18px;
}
.process-desc-ab{
  text-align: unset;
  max-width: 276px;
}
.fm-head{
font-size: 28px;
font-style: normal;
font-weight: 600;
line-height: normal;
}










}
</style>

<section class="section-{{ section.id }}-padding fade-up">
  <div class="page-width">
    <div class="fm_waste_container">
      <div class="fm-wst-content">
        <div class="fm-head">{{ section.settings.fm_head }}</div>
        <div class="fm-desc">{{ section.settings.fm_desc }}</div>
      </div>

      <div class="fm-wast-block">
        {% for block in section.blocks %}
          <div class="process-card-ab">
            {% if block.settings['process-icon'] != blank %}
              <div class="process-icon-ab">
                {{
                  block.settings['process-icon']
                  | image_url: width: 1440
                  | image_tag:
                    widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                    class: 'proces-ab',
                    alt: 'image',
                    loading: 'eager'
                }}
              </div>
            {% endif %}
            <div class="proces-wrap-ab">
            {% if block.settings['process-step'] != blank %}
              <span class="process-step-ab">{{ block.settings['process-step'] }}</span>
            {% endif %}
            {% if block.settings['process-title'] != blank %}
              <h3 class="process-title-ab">{{ block.settings['process-title'] }}</h3>
            {% endif %}
            {% if block.settings['process-desc'] != blank %}
              <p class="process-desc-ab">{{ block.settings['process-desc'] }}</p>
            {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "From Waste Section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back_color",
      "label": "Background Color"
    },
    {
      "type": "text",
      "id": "fm_head",
      "label": "Main Heading"
    },
    {
      "type": "text",
      "id": "fm_desc",
      "label": "Sub Heading"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Add Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "process-icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "process-step",
          "label": "Step Count"
        },
        {
          "type": "text",
          "id": "process-title",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "process-desc",
          "label": "Sub Heading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "From Waste Section"
    }
  ]
}
{% endschema %}
