<style>
  .video-hero-section {
    position: relative;
    width: 100%;
  }

  .video-wrapper { position: relative; width: 100%; }

  .video-hero-video {
    width: 100%;
    object-fit: cover;
    display: block;
    height: 75vh;
    cursor: pointer;
  }

  .hero-content {
    z-index: 2;
    color: #fff;
    max-width: 650px;
    position: absolute;
    top: 50%;
    left: 30px;
    transform: translate(0, -50%);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .hero-heading { margin: 0; }

  .hero-heading,
  .hero-heading p {
    color: var(--White, #FFF);
    font-family: "League Spartan";
    font-size: 48px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
    margin: 0px;
    padding-bottom: 10px;
  }

  .hero-heading strong {
    font-weight: 800;
    color: #EDFF73;
    font-family: "Playfair Display";
    margin: 0px;
  }

  .herp-desc p {
    max-width: 675px;
    color: var(--White, #FFF);
    font-family: Quicksand;
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 22px;
  }

  .cta-button {
    color: #FFF6E8;
    font-family: Quicksand;
    font-size: 20px;
    max-width: max-content;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    background: var(--almond-forest, #8C7A6E);
    display: flex;
    padding: 16px 34px;
    justify-content: center;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    margin-top: 8px;
  }

  .cta-button:hover { background: #6B5B4C; transform: translateY(-2px); }
  .cta-button:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }

  .video-pause-btn {
    position: absolute;
    bottom: 16px;
    right: 16px;
    z-index: 10;
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease;
    padding: 0;
  }
  .video-pause-btn:hover { background: rgba(0,0,0,0.8); }
  .video-pause-btn:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }
  .video-pause-btn svg { width: 16px; height: 16px; fill: #fff; }

  .expert-card {
    position: absolute;
    right: 80px;
    bottom: 40px;
    border-radius: 12px;
    padding: 20px;
    min-width: 200px;
    z-index: 3;
    text-align: center;
    background: rgba(255, 255, 255, 0.20);
    backdrop-filter: blur(15px);
    max-width: 204px;
  }

  .expert-number {
    color: var(--Green, #CAD95F);
    font-family: Outfit !important;
    font-size: 40px;
    font-style: normal;
    font-weight: 700;
    line-height: 130%;
    margin-bottom: 12px;
  }
  .expert-title {
    color: var(--White, #FFF);
    text-align: center;
    font-family: "Playfair Display" !important;
    font-size: 20px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    text-transform: capitalize;
    margin-bottom: 8px;
  }
  .expert-description {
    color: var(--White, #FFF);
    text-align: center;
    font-family: Outfit !important;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
    margin: 0px;
    letter-spacing: 0px;
  }

  .mj-ev-icon img { width: 42px; height: 42px; display: block; }
  .vd-block-wrap { display: flex; align-items: center; gap: 16px; }
  .maj-ev-main-wrap { display: flex; justify-content: center; align-items: center; gap: 8px; }

  .mj-feature-heading {
    color: var(--White, #FFF);
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    font-family: "League Spartan";
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    padding: 0;
    margin: -1px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-button:hover { transform: none; }
  }

  @media (max-width: 768px) {
    .hero-heading { font-size: 28px; }
    .expert-card { right: 20px; bottom: 20px; padding: 16px; min-width: 160px; }
    .expert-number { font-size: 40px; margin: 0px; }
    .desktop-video { display: none; }
    .mobile-video { display: block; }
  }

  @media (min-width: 769px) {
    .mobile-video { display: none; }
    .desktop-video { display: block; }
  }

  @media (max-width: 767px) {
    .video-wrapper { display: flex; flex-direction: column; position: relative; }
    .vd-block-wrap { flex-wrap: wrap; justify-content: center; }
    .hero-content {
      z-index: 5; gap: 10px; left: 0; padding: 0 20px; text-align: center;
    }
    .expert-card {
      position: absolute;
      right: 20px; bottom: 20px;
      border-radius: 12px;
      padding: 16px;
      min-width: 160px;
      z-index: 6;
    }
    .hero-heading,
    .hero-heading p { font-size: 28px; padding: 0; margin-bottom: 4px; }
    .mj-ev-icon img { width: 16px; height: 16px; }
    .mj-feature-heading { font-size: 12px; font-weight: 400; }
    .herp-desc p { font-size: 14px; font-weight: 500; margin-bottom: 10px; }
    .cta-button { max-width: fit-content; margin: 0 auto; font-size: 18px; }
    .desktop-video { display: none; }
    .mobile-video { display: block; }
    .expert-title {
      color: var(--White, #FFF);
      font-family: "Playfair Display";
      font-size: 18px;
      font-weight: 600;
      line-height: 120%;
      text-transform: capitalize;
      margin: 0 0 4px;
      text-align: left;
    }
    .expert-description {
      color: var(--White, #FFF);
      text-align: center;
      font-family: Outfit !important;
      font-size: 14px;
      font-weight: 400;
      line-height: 120%;
    }
    .video-hero-video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      cursor: pointer;
      min-height: 449px;
    }
    .ms-vedo-wrap { position: relative; }
    .expert-card {
      position: absolute;
      left: 50%;
      bottom: 35%;
      min-width: 342px;
      transform: translateX(-50%);
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 12px;
      padding: 16px;
    }
    .video-hero-section { padding: 20px 0px 0; }
    .video-pause-btn { bottom: auto; top: 12px; right: 12px; }
  }
</style>

{%- liquid
  assign heading_plain = section.settings.heading | strip_html | strip
  assign desc_plain = section.settings.desc | strip_html | strip
  assign cta_text = section.settings.cta_text | strip
-%}

<section
  class="video-hero-section fade-up"
  data-section-id="{{ section.id }}"
  data-section-type="video-hero"
  {% if heading_plain != blank %}
    aria-label="{{ heading_plain | truncate: 80 | escape }}"
  {% endif %}
>
  <div class="video-wrapper">
    <div class="ms-vedo-wrap">

      {% if section.settings.cs_video != blank %}
        {% assign video_poster = section.settings.cs_video.preview_image | image_url: width: 1600 %}
        {{
          section.settings.cs_video
          | video_tag:
            class: 'video-hero-video',
            autoplay: true,
            loop: true,
            muted: true,
            playsinline: true,
            controls: false,
            preload: 'metadata',
            poster: video_poster
        }}
      {% endif %}

      <div class="video-overlay" aria-hidden="true"></div>

      {% if section.settings.cs_video != blank %}
        <button
          class="video-pause-btn"
          id="video-pause-btn-{{ section.id }}"
          type="button"
          aria-label="{{ 'accessibility.pause_video' | t }}"
          aria-pressed="false"
        >
          <svg class="icon-pause" aria-hidden="true" focusable="false" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="4" width="4" height="16" rx="1"/>
            <rect x="14" y="4" width="4" height="16" rx="1"/>
          </svg>
          <svg class="icon-play" aria-hidden="true" focusable="false" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:none;">
            <polygon points="5,3 19,12 5,21"/>
          </svg>
        </button>
      {% endif %}

    </div>

    <div class="hero-content">

      {% if desc_plain != blank %}
        <span id="video-hero-desc-{{ section.id }}" class="visually-hidden">
          {{ desc_plain | escape }}
        </span>
      {% endif %}

      {% if heading_plain != blank %}
        <h2 class="hero-heading">{{ heading_plain | escape }}</h2>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="vd-block-wrap" role="list">
          {% for block in section.blocks %}
            {%- liquid
              assign feat_label = block.settings.feature_heading | strip
              if feat_label == blank
                assign feat_label = 'Feature ' | append: forloop.index
              endif
              assign feat_alt = block.settings.feature_icon.alt | default: feat_label
            -%}
            <div class="maj-ev-main-wrap" role="listitem" {{ block.shopify_attributes }}>
              {% if block.settings.feature_icon != blank %}
                <div class="mj-ev-icon">
                  <img
                    src="{{ block.settings.feature_icon | image_url: width: 200 }}"
                    loading="lazy"
                    width="42"
                    height="42"
                    alt="{{ feat_alt | escape }}"
                  >
                </div>
              {% endif %}
              {% if block.settings.feature_heading != blank %}
                <div class="mj-feature-content">
                  <div class="mj-feature-heading" aria-hidden="true">
                    {{ block.settings.feature_heading | escape }}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.desc != blank %}
        <div class="herp-desc">{{ section.settings.desc }}</div>
      {% endif %}

      {% if cta_text != blank and section.settings.cta_url != blank %}
        <a
          href="{{ section.settings.cta_url }}"
          class="cta-button"
          aria-label="{{ cta_text | append: ' — ' | append: heading_plain | strip | escape }}"
        >
          {{ cta_text | escape }}
        </a>
      {% endif %}

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var video = section.querySelector('.video-hero-video');
    var btn = section.querySelector('#video-pause-btn-{{ section.id }}');
    if (!video || !btn) return;

    video.setAttribute('aria-label', {{ heading_plain | json }});
    {% if desc_plain != blank %}
      video.setAttribute('aria-describedby', 'video-hero-desc-{{ section.id }}');
    {% endif %}
    video.setAttribute('role', 'img');

    var iconPause = btn.querySelector('.icon-pause');
    var iconPlay = btn.querySelector('.icon-play');

    function setPaused(paused) {
      if (paused) {
        btn.setAttribute('aria-pressed', 'true');
        btn.setAttribute('aria-label', 'Play background video');
        iconPause.style.display = 'none';
        iconPlay.style.display = '';
      } else {
        btn.setAttribute('aria-pressed', 'false');
        btn.setAttribute('aria-label', 'Pause background video');
        iconPause.style.display = '';
        iconPlay.style.display = 'none';
      }
    }

    btn.addEventListener('click', function () {
      if (video.paused) { video.play(); setPaused(false); }
      else              { video.pause(); setPaused(true); }
    });

    // Respect prefers-reduced-motion (WCAG 2.3.3)
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    function applyMotionPref() {
      if (reduceMotion.matches) {
        video.pause();
        video.removeAttribute('autoplay');
        setPaused(true);
      }
    }
    applyMotionPref();
    if (reduceMotion.addEventListener) {
      reduceMotion.addEventListener('change', applyMotionPref);
    } else if (reduceMotion.addListener) {
      reduceMotion.addListener(applyMotionPref);
    }
  });
</script>

{% schema %}
{
  "name": "Video Hero Section",
  "settings": [
    { "type": "video", "id": "cs_video", "label": "Upload Video File" },
    { "type": "image_picker", "id": "desktop_poster", "label": "Desktop Poster Image" },
    { "type": "image_picker", "id": "mobile_poster", "label": "Mobile Poster Image" },
    { "type": "richtext", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "desc", "label": "Description" },
    { "type": "text", "id": "cta_text", "label": "Button Text", "default": "SHOP NOW" },
    { "type": "url", "id": "cta_url", "label": "Button Link" },
    { "type": "text", "id": "expert_number", "label": "Expert Number", "default": "#1" },
    { "type": "text", "id": "expert_title", "label": "Expert Title", "default": "Expert Recommended" },
    { "type": "text", "id": "expert_description", "label": "Expert Description", "default": "Best Product for your Mind and Brain" }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "feature_icon", "label": "Feature Icon" },
        { "type": "text", "id": "feature_heading", "label": "Feature Heading" }
      ]
    }
  ],
  "presets": [
    { "name": "Video Hero Section", "category": "Custom" }
  ]
}
{% endschema %}