<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings['back-color'] }};
  }
  .section-{{ section.id }}-padding .page-width { padding: 0; }

  .csym-Jood-top-info {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 20px;
    max-width: 596px;
    margin: 0 auto;
  }
  .Main-haeding-csym p {
    font-family: "League Spartan";
    font-weight: 600;
    text-transform: uppercase;
    font-style: normal;
    font-size: 40px;
    line-height: normal;
    letter-spacing: 0px;
    text-align: center;
    color: #0C2421;
  }
  .csym-Jood-stars { display: flex; align-items: center; gap: 2px; }

  .csym-Jood-main-heading {
    max-width: 856px;
    color: #0C2421;
    margin: 0 auto;
    font-family: Outfit;
    font-weight: 400;
    font-style: normal;
    font-size: 18px;
    line-height: 24px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    padding: 16px 0 30px;
  }
  .csym-Jood-reviews-wrapper { display: flex; gap: 29px; justify-content: center; }
  .csym-Jood-top-info em {
    font-family: ITC Clearface Std;
    font-weight: 400;
    font-style: italic;
    font-size: 40px;
    line-height: 110%;
    letter-spacing: 0px;
    text-align: center;
  }
  .csym-Jood-review-block {
    max-width: 420px;
    box-sizing: border-box;
    display: flex !important;
    flex-direction: column;
    gap: 16px;
  }
  .review-stars {
    display: flex;
    max-width: 85px;
    gap: 2px;
    margin: 0 auto;
    justify-content: center;
    align-items: center;
  }
  .review-title {
    color: var(--Secondary-Black, #000);
    text-align: center;
    font-family: "League Spartan";
    font-size: 32px;
    font-style: normal;
    font-weight: 400;
    line-height: 40px;
    max-width: 300px;
    margin: 0 auto;
    letter-spacing: -0.32px;
  }
  .review-title p { margin: 0; }
  .review-text {
    color: var(--Secondary-Black, #000);
    text-align: center;
    font-family: Quicksand;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 20px;
  }
  .verify_cs { display: flex; justify-content: center; align-items: center; gap: 4px; }
  .verify-badge svg { width: 16px; height: 16px; aspect-ratio: 1/1; display: block; }
  .vrfy_txt {
    color: var(--almond-forest, #8C7A6E);
    text-align: center;
    font-family: "League Spartan";
    font-size: 12px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
  }
  .review-author {
    color: var(--Secondary-Black, #000);
    text-align: center;
    font-family: Quicksand;
    font-size: 14px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 6px;
  }
  .verified-badge {
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    color: #000;
    font-family: Satoshi;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 18.2px;
    letter-spacing: 1.4px;
  }
  .verified-badge svg { margin: 0px 9px; }

  .swipe { position: relative; overflow: hidden; }
  .cs_rating_wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
  }
  .cs_rat_icon { width: 108.001px; display: block; }
  .cs_rating p {
    color: #000;
    font-family: Quicksand;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
  }
  .cs_rating p strong {
    color: #000;
    text-align: center;
    font-family: "League Spartan";
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
  }
  .fd_main_btn {
    color: #444141;
    font-family: Quicksand;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    border: 1px solid #444141;
    display: flex;
    width: 234px;
    padding: 12px 10px;
    justify-content: center;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
  }
  .fd_main_btn:hover,
  .fd_main_btn:focus-visible {
    color: #fff;
    background-color: #8C7A6E;
    border-color: #8C7A6E;
  }
  .fd_main_btn:focus-visible { outline: 2px solid #8C7A6E; outline-offset: 2px; }
  .cs_cts_btn { display: flex; justify-content: center; align-items: center; }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.mbl_padding_top }}px;
      padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
    }
    .swipe .swiper-pagination-bullet-active { background: #DDDDFB !important; border: 1px solid !important; }
    .review-title { font-size: 28px; min-height: 80px; }
    .Main-haeding-csym p { font-size: 28px; }
    .swipe .swiper-pagination-bullet { background: transparent; border: 1px solid #484444; }
    .csym-Jood-top-info { font-size: 32px; }
    .csym-Jood-top-info em { font-size: 32px; }
    .csym-Jood-main-heading {
      padding: 16px 0 24px;
      font-family: Outfit;
      font-weight: 400;
      font-style: normal;
      font-size: 16px;
      line-height: 22px;
      letter-spacing: 0%;
      text-align: center;
      vertical-align: middle;
      max-width: 346px;
    }
    .csym-Jood-review-block .csym-Jood-reviews-wrapper {
      flex-direction: column;
      gap: 16px;
      align-items: center;
    }
    .cs_rating p { font-size: 14px; }
    .cs_rating p strong { font-size: 14px; }
    .review-text { font-size: 14px; max-width: 292px; margin: 0 auto; }
    .review-stars {
      display: flex;
      max-width: 85px;
      gap: 2px;
      margin: 0 auto;
      justify-content: center;
      align-items: center;
    }
    .swipe .swiper-pagination-horizontal { bottom: 0px; }
  }

  .reviews-cards-slider .swiper-pagination-bullet {
    background: transparent;
    opacity: 1;
    border: 1px solid #0C2421;
    transition: all 0.3s ease;
    width: 8px;
    height: 8px;
  }
  .reviews-cards-slider .swiper-pagination-bullet-active {
    background: #0C2421;
    border: none;
    opacity: 1;
  }
  .reviews-cards-slider {
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: 34px 0;
  }
  .reviews-cards-slider .swiper-wrapper {
    display: flex;
    width: max-content;
    animation: scroll-reviews 30s linear infinite;
  }
  .csym-Jood-review-block {
    flex: 0 0 auto;
    margin-right: 16px;
    border: 1px solid rgba(0, 0, 0, 0.30);
    background: #F0E9D3;
    padding: 24px;
  }
  .reviews-cards-slider .swiper-pagination { position: absolute; bottom: 0; z-index: 1; }
  .reviews-cards-slider .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    background: transparent;
    border: 1px solid #0C2421;
    transition: all 0.3s ease;
  }
  .reviews-cards-slider .swiper-pagination-bullet-active { background: #0C2421; border: none; }
  @media (prefers-reduced-motion: reduce) {
    .reviews-cards-slider .swiper-wrapper { animation: none; }
  }
  @keyframes scroll-reviews {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

{%- liquid
  assign rating_alt = section.settings.rate_icon.alt | default: 'Customer rating'
  assign main_heading_plain = section.settings.heading_1 | strip_html | strip
  assign sub_heading_plain = section.settings.heading | strip_html | strip
-%}

<section
  id="review_mm"
  class="section-{{ section.id }}-padding swipe bounce-up fade-up"
  {% if main_heading_plain != blank %}
    aria-labelledby="review-heading-{{ section.id }}"
  {% endif %}
>
  <div class="page-width">
    <div class="csym-Jood-top-info">
      <div class="cs_rating_wrap">
        {% if section.settings.rate_icon != blank %}
          <img
            class="cs_rat_icon"
            src="{{ section.settings.rate_icon | image_url: width: 220 }}"
            width="108"
            height="22"
            loading="lazy"
            alt="{{ rating_alt | escape }}"
          >
        {% endif %}
        {% if section.settings.rs_rating != blank %}
          <div class="cs_rating">{{ section.settings.rs_rating }}</div>
        {% endif %}
      </div>
      {% if main_heading_plain != blank %}
        <h2 id="review-heading-{{ section.id }}" class="Main-haeding-csym">
          {{ section.settings.heading_1 }}
        </h2>
      {% endif %}
    </div>

    {% if sub_heading_plain != blank %}
      <p class="csym-Jood-main-heading">{{ section.settings.heading | escape }}</p>
    {% endif %}

    <div
      class="reviews-cards-slider swiper-container"
      role="region"
      aria-roledescription="carousel"
      aria-label="Customer reviews"
    >
      <div class="swiper-wrapper" role="list">

        {%- comment -%} Real (announced) blocks {%- endcomment -%}
        {% for block in section.blocks %}
          {%- liquid
            assign stars_count = block.settings.block_rating | default: 5
            assign reviewer = block.settings.reviewer_name | strip
            assign title_plain = block.settings.review_title | strip_html | strip
            if title_plain == blank
              assign title_plain = 'Review ' | append: forloop.index
            endif
          -%}
          <div
            class="csym-Jood-review-block swiper-slide"
            role="listitem"
            aria-label="{{ title_plain | escape }} review by {{ reviewer | default: 'verified customer' | escape }}"
            {{ block.shopify_attributes }}
          >
            <div
              class="review-stars"
              role="img"
              aria-label="Rated {{ stars_count }} out of 5 stars"
            >
              {% for i in (1..stars_count) %}
                {% if block.settings.block_star_img != blank %}
                  <img
                    src="{{ block.settings.block_star_img | image_url: width: 40 }}"
                    width="14"
                    height="14"
                    loading="lazy"
                    alt=""
                    aria-hidden="true"
                  >
                {% endif %}
              {% endfor %}
            </div>

            {% if block.settings.review_title != blank %}
              <h3 class="review-title">{{ block.settings.review_title }}</h3>
            {% endif %}
            {% if block.settings.review_text != blank %}
              <div class="review-text">{{ block.settings.review_text | escape | newline_to_br }}</div>
            {% endif %}

            <div class="review-author">
              {{ block.settings.reviewer_name | escape }}
              {% if block.settings.reviewer_name != blank %}
                <div class="verify_cs">
                  <span class="verify-badge" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" focusable="false">
