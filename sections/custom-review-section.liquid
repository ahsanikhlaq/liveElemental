                      <path d="M10.2785 5.96215L7.26852 9.04082L5.65852 7.88615C5.55058 7.80898 5.41639 7.77784 5.2855 7.79959C5.15459 7.82135 5.0377 7.89422 4.96052 8.00215C4.88334 8.1101 4.8522 8.24428 4.87396 8.37518C4.89571 8.50608 4.96858 8.62298 5.07652 8.70015L7.03786 10.1002C7.13472 10.17 7.25344 10.2026 7.37238 10.1922C7.49132 10.1818 7.60258 10.129 7.68586 10.0435L10.9932 6.65815C11.0416 6.61179 11.0803 6.55615 11.1068 6.49455C11.1333 6.43295 11.1472 6.36663 11.1475 6.29957C11.1479 6.23251 11.1347 6.16606 11.1089 6.10416C11.0831 6.04228 11.045 5.98623 10.9971 5.93934C10.9491 5.89246 10.8922 5.8557 10.8297 5.83126C10.7673 5.80682 10.7006 5.79519 10.6335 5.79707C10.5665 5.79895 10.5005 5.8143 10.4395 5.84221C10.3785 5.87011 10.3238 5.90999 10.2785 5.95948V5.96215Z" fill="#8C7A6E"/>
                    </svg>
                  </span>
                  <span class="vrfy_txt">VERIFIED CUSTOMER</span>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}

        {%- comment -%} Decorative duplicate set for seamless scroll {%- endcomment -%}
        {% for block in section.blocks %}
          {%- liquid
            assign stars_count = block.settings.block_rating | default: 5
          -%}
          <div class="csym-Jood-review-block swiper-slide" aria-hidden="true">
            <div class="review-stars">
              {% for i in (1..stars_count) %}
                {% if block.settings.block_star_img != blank %}
                  <img
                    src="{{ block.settings.block_star_img | image_url: width: 40 }}"
                    width="14"
                    height="14"
                    loading="lazy"
                    alt=""
                  >
                {% endif %}
              {% endfor %}
            </div>
            {% if block.settings.review_title != blank %}
              <div class="review-title">{{ block.settings.review_title }}</div>
            {% endif %}
            {% if block.settings.review_text != blank %}
              <div class="review-text">{{ block.settings.review_text | escape | newline_to_br }}</div>
            {% endif %}
            <div class="review-author">
              {{ block.settings.reviewer_name | escape }}
              {% if block.settings.reviewer_name != blank %}
                <div class="verify_cs">
