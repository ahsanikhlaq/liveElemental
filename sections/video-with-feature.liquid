      padding-right: {{ section.settings.mbl_padding_right}}px;
  }
    .bottle-images{
      margin-right: 12px;
    }
    .feature-produt-left{
    display:none;
    }
    .home-feature-lists{
    padding: 41px 15px;
    margin: 0 10px;
    gap:24px;
}
  .feature-produt-left {
      width: 100%;
  }
  .feature-product-right {
      width: 100%;
  }
   .prod-main-feature-section{
    flex-direction: column;
     gap:24px;
   }
