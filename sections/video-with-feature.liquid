  }
  .wrinkle-price-container{
        margin-bottom: 17px;
  }
  .wrinkle-cart-btn {
    font-size: 12px;
    line-height: 13.697px;
    /* padding: 9px 37px; */
  }



    }
</style>

<section class="section-{{ section.id }}-padding bounce-up fade-up">
  <div class="page-width">
    <div class="prod-main-feature-section">
      <div class="feature-produt-left">
        {% if section.settings.video != blank %}
          <div class="video-wrapper-feature">
            {{
              section.settings.video
              | video_tag:
                class: 'feature-vid',
                image_size: '1100x',
                controls: false,
                muted: true,
                autoplay: true,
                loop: true,
                playsinline: true,
                id: 'video1'
            }}
          </div>

          {% comment %}
            <div class="video-play-icon-svg-vid" onclick="toggleVideo(this, 'video1')">
              {{
                section.settings['play-icon-vid']
                | image_url: width: 500
                | image_tag:
                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600',
                  alt: 'play icon',
                  class: 'image-play-icon-vid',
                  loading: 'lazy'
              }}
            </div>
          {% endcomment %}
        {% else %}
          {% if section.settings['feature-main-image1'] != blank %}
            <div class="produc-feature-main-image">
              <img
                class="pro-feature-img-main"
                src="{{ section.settings.feature-main-image1 | image_url: width: 1200 }}"
                loading="lazy"
                width="100%"
                height="auto"
              >
            </div>
          {% endif %}
        {% endif %}
      </div>
      <div class="feature-product-right">
        <div class="product-feature-section-main-heading">{{ section.settings['feature-main-heading'] }}</div>
        <div class="produt-feature-section-main-desc">{{ section.settings['feature-main-desc'] }}</div>
        <div class="home-feature-lists">
          {% for block in section.blocks %}
            <div class="home-list-icon-main">
              <div class="home-list-icon">
                <img src="{{ block.settings.image | image_url: width: 200 }}" loading="lazy" alt="">
              </div>
              <div class="home-features-content">
                <div class="home-list-heading">{{ block.settings['features-heading'] }}</div>
                <div class="home-list-desc">{{ block.settings['features-description'] }}</div>
              </div>
            </div>
          {% endfor %}
          {% comment %} <div class="shop-btn">
            <a href="{{ section.settings.shop_btn }}" class="shop-btn-feature">SHOP NOW</a>
          </div> {% endcomment %}
        </div>
      </div>
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Video With Features",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding left",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Right",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Left Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Right Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back-color",
      "label": "Background Color"
    },
    {
      "type": "richtext",
      "id": "feature-main-heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "feature-main-desc",
      "label": "Description"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "play-icon-vid",
      "label": "Play Icon"
    },
  ],
  "blocks": [
    {
      "type": "blocks",
      "name": "Add Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "features-heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "features-description",
          "label": "Features Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video With Features"
    }
  ]
}
{% endschema %}
