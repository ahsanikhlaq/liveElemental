{% stylesheet %}
.csym-container-mf {
    overflow: hidden;
    background-color: {{section.settings.background_color}};
    padding: 10px 65px;
}

.csym-track-mf {
    display: flex;
    animation: scroll-left 40s linear infinite;
    width: max-content;
    will-change: transform;
}

/* FIX 5: Pause animation for reduced motion users */
@media (prefers-reduced-motion: reduce) {
    .csym-track-mf {
        animation: none;
    }
}

.feature-icon-item-mf {
    display: flex;
    align-items: center;
    margin-right: 58px;
    white-space: nowrap;
}

.feature-icon-item-mf img {
    max-width: 20px;
    max-height: 20px;
    flex-shrink: 0;
    margin-right: 10px;
    width: 100%;
    height: 100%;
}

.feature-icon-item-mf span {
    color: var(--White, #FFF);
    font-family: Quicksand;
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 22px;
}

@keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
{% endstylesheet %}

{% if section.settings.hide %}
<style>
    @media (min-width: 768px) {
        .sec-{{ section.id }} {
            display: none;
        }
    }
</style>
{% endif %}

<!-- FIX 3: Added role="region" and aria-label so assistive tech identifies this section -->
<div class="csym-container-mf fade-up sec-{{ section.id }}"
     style="background-color: {{section.settings.background_color}};"
     role="region"
     aria-label="Feature highlights">

    <div class="csym-track-mf">

        <!-- FIX 2 & 4: First set is the real content — no aria-hidden -->
        {% for block in section.blocks %}
            <div class="feature-icon-item-mf">
                {% if block.settings.icon %}
                    <!-- FIX 4: Icon is decorative (label already provides the text), so alt="" is correct -->
                    <img src="{{ block.settings.icon | image_url: width: 200 }}"
                         alt=""
                         role="presentation"
                         loading="lazy">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

        <!-- FIX 2: All duplicate loops hidden from screen readers -->
        {% for block in section.blocks %}
            <div class="feature-icon-item-mf" aria-hidden="true">
                {% if block.settings.icon %}
                    <img src="{{ block.settings.icon | image_url: width: 200 }}" alt="" loading="lazy">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

        {% for block in section.blocks %}
            <div class="feature-icon-item-mf" aria-hidden="true">
                {% if block.settings.icon %}
                    <img src="{{ block.settings.icon | image_url: width: 200 }}" alt="" loading="lazy">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

        {% for block in section.blocks %}
            <div class="feature-icon-item-mf" aria-hidden="true">
                {% if block.settings.icon %}
                    <img src="{{ block.settings.icon | image_url: width: 200 }}" alt="" loading="lazy">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

    </div>
</div>