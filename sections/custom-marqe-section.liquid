{% stylesheet %}
.csym-container-mf {
    overflow: hidden;
    background-color: {{section.settings.background_color}};
    padding: 10px 65px;
}

.csym-track-mf {
    display: flex;
    animation: scroll-left 40s linear infinite;
    width: max-content;
    will-change: transform;
}

@media (prefers-reduced-motion: reduce) {
    .csym-track-mf {
        animation: none;
    }
}

.feature-icon-item-mf {
    display: flex;
    align-items: center;
    margin-right: 58px;
    white-space: nowrap;
}

.feature-icon-item-mf img {
    max-width: 20px;
    max-height: 20px;
    flex-shrink: 0;
    margin-right: 10px;
    width: 100%;
    height: 100%;
}

.feature-icon-item-mf span {
    color: var(--White, #FFF);
    font-family: Quicksand;
    font-size: 16px;
    font-style: normal;
    font-weight: 500;
    line-height: 22px;
}

@keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
{% endstylesheet %}

{% if section.settings.hide %}
<style>
    @media (min-width: 768px) {
        .sec-{{ section.id }} {
            display: none;
        }
    }
</style>
{% endif %}

<div class="csym-container-mf fade-up sec-{{ section.id }}"
     style="background-color: {{section.settings.background_color}};"
     role="region"
     aria-label="Feature highlights">

    <div class="csym-track-mf">

        <!-- Real content: visible to screen readers -->
        {% for block in section.blocks %}
            <div class="feature-icon-item-mf">
                {% if block.settings.icon %}
                    <img
                        src="{{ block.settings.icon | image_url: width: 200 }}"
                        alt="{{ block.settings.title }}"
                        title="{{ block.settings.title }}"
                        loading="lazy"
                        width="20"
                        height="20">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

        <!-- Duplicate 1: hidden from screen readers -->
        {% for block in section.blocks %}
            <div class="feature-icon-item-mf" aria-hidden="true">
                {% if block.settings.icon %}
                    <img
                        src="{{ block.settings.icon | image_url: width: 200 }}"
                        alt=""
                        loading="lazy"
                        width="20"
                        height="20">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

        <!-- Duplicate 2: hidden from screen readers -->
        {% for block in section.blocks %}
            <div class="feature-icon-item-mf" aria-hidden="true">
                {% if block.settings.icon %}
                    <img
                        src="{{ block.settings.icon | image_url: width: 200 }}"
                        alt=""
                        loading="lazy"
                        width="20"
                        height="20">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

        <!-- Duplicate 3: hidden from screen readers -->
        {% for block in section.blocks %}
            <div class="feature-icon-item-mf" aria-hidden="true">
                {% if block.settings.icon %}
                    <img
                        src="{{ block.settings.icon | image_url: width: 200 }}"
                        alt=""
                        loading="lazy"
                        width="20"
                        height="20">
                {% endif %}
                <span>{{ block.settings.title }}</span>
            </div>
        {% endfor %}

    </div>
</div>

{% schema %}
{
    "name": "CSTM Marquee",
    "tag": "section",
    "class": "scrolling-feature-icons",
    "settings": [
        {
            "type": "checkbox",
            "id": "hide",
            "label": "Hide Desktop"
        },
        {
            "type": "color",
            "id": "background_color",
            "label": "Background Color",
            "default": "#E2F1C4",
            "info": "Choose a background color for the section"
        }
    ],
    "blocks": [
        {
            "type": "feature",
            "name": "Feature",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "icon",
                    "label": "Icon"
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Feature Title",
                    "default": "Feature"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "CSTM Marquee",
            "category": "Custom"
        }
    ]
}
{% endschema %}