{% style %}
  #compare-nutrition-{{ section.id }} {
    position: relative;
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    {% if section.settings.bg_image_desktop != blank %}
      background-image: url({{ section.settings.bg_image_desktop | img_url: 'master' }});
    {% endif %}
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    display: flex;
    height: 702px;
    padding: 155px 60px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 10px;
  }

  #compare-nutrition-{{ section.id }} .page-width {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
  }

  #compare-nutrition-{{ section.id }} .compare-content {
    max-width: 550px;
    display: flex;
    flex-direction: column;
  }

  #compare-nutrition-{{ section.id }} .compare-nutrition-content {
    max-width: 550px;
  }

  #compare-nutrition-{{ section.id }} .compare-nutrition-heading {
    font-size: 36px;
    font-weight: 600;
    margin-bottom: 20px;
  }

  #compare-nutrition-{{ section.id }} .compare-nutrition-description {
    font-size: 16px;
    line-height: 1.6;
    max-width: 500px;
  }

  #compare-nutrition-{{ section.id }} .compare-nutrition-blocks {
    flex: 1 1 45%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  #compare-nutrition-{{ section.id }} .compare-nutrition-block img {
    width: 100%;
    max-width: 21px;
    height: auto;
  }

  .compare-heading p {
    color: {{ section.settings.heading_color }};
    font-family: "League Spartan" !important;
    font-size: 72px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
    margin: 0;
    padding-bottom: 8px;
  }

  .about_pt_main .compare-heading p {
    color: {{ section.settings.heading_color_about }};
    font-family: "League Spartan" !important;
    font-size: 72px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
    max-width: 542px;
    padding-bottom: 6px;
  }

  .about_pt_main .compare-description {
    color: {{ section.settings.description_color_about }};
    font-family: Quicksand !important;
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    max-width: 500px;
  }

  .compare-heading p strong {
    color: {{ section.settings.heading_accent_color }};
    font-family: "Roboto Condensed" !important;
    font-size: 64px;
    font-style: normal;
    font-weight: 700;
    line-height: 110%;
    text-transform: uppercase;
    margin: 0px;
  }

  .compare-blocks {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin: 0 0 32px;
  }

  .compare-nutrition-wrapper {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    text-align: left;
    z-index: 999;
  }

  .compare-nutrition-block {
    display: flex;
    gap: 16px;
    align-items: center;
    color: white;
  }

  .compare-block-title strong {
    font-family: Outfit !important;
    font-weight: 700;
    font-style: Bold;
    font-size: 14px;
    line-height: 100%;
    letter-spacing: 0px;
  }

  .compare-block-title p {
    font-family: Outfit !important;
    font-weight: 300;
    font-style: Light;
    font-size: 14px;
    line-height: normal;
    letter-spacing: 0px;
    margin: 0px;
  }

  .compare-description {
    color: {{ section.settings.description_color }};
    font-family: 'Quicksand' !important;
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    max-width: 336px;
    margin: 0 0 24px;
  }

  .gurentee-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding-top: 16px;
  }

  .gurentee-text {
    color: #000;
    font-family: "Roboto Condensed";
    font-size: 12px;
    font-style: normal;
    font-weight: 500;
    line-height: 120%;
    letter-spacing: 0;
  }

  .try-btn {
    text-decoration: none;
    display: flex;
    background: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    font-family: Quicksand;
    font-size: 20px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    display: flex;
    padding: 16px 34px;
    justify-content: center;
    align-items: center;
    gap: 12px;
    transition: all 0.3s ease;
  }

  .try-btn:hover,
  .try-btn:focus-visible {
    background: {{ section.settings.button_bg_color_hover }};
    transform: scale(1.05);
  }

  .try-btn:focus-visible {
    outline: 2px solid {{ section.settings.button_text_color }};
    outline-offset: 2px;
  }

  .gurentee-icon {
    display: block;
    width: 24px;
    height: 24px;
  }

  .star-mj-ico {
    width: 120px;
    height: 20px;
    display: block;
  }

  .rat-mj-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .star-mj-rat {
    color: var(--black, #000);
    font-family: "Roboto Condensed";
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 120%;
    text-decoration-line: underline;
    text-decoration-style: solid;
    text-decoration-skip-ink: auto;
    text-decoration-thickness: auto;
    text-underline-offset: auto;
  }

  @media (max-width: 786px) {
    #compare-nutrition-{{ section.id }} {
      {% if section.settings.bg_image_mobile != blank %}
        background-image: url({{ section.settings.bg_image_mobile | img_url: 'master' }});
      {% endif %}
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      display: flex;
      height: 656px;
      padding: 414px 25px 46px 25px;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
    }

    .about_pt_main {
      justify-content: flex-start;
      height: unset !important;
    }

    .about_pt_main .compare-heading p {
      color: {{ section.settings.heading_color_mobile }};
      text-align: center;
      font-family: "League Spartan";
      font-size: 44px;
      font-style: normal;
      font-weight: 600;
      line-height: normal;
      text-transform: uppercase;
    }

    .about_pt_main .compare-description {
      color: {{ section.settings.description_color_mobile }};
      text-align: center;
      font-family: Quicksand;
      font-size: 16px;
      font-style: normal;
      font-weight: 500;
      line-height: 22px;
      max-width: 340px;
      margin: 0 auto;
    }

    .star-mj-rat {
      font-size: 16px;
    }

    .star-mj-ico {
      width: 102px;
    }

    .rat-mj-wrap {
      gap: 8px;
      padding-bottom: 4px;
    }

    .gurentee-wrap {
      padding-top: 16px;
    }

    #compare-nutrition-{{ section.id }} .page-width {
      flex-direction: column;
      text-align: center;
    }

    #compare-nutrition-{{ section.id }} .compare-nutrition-content {
      flex: unset;
      width: 100%;
    }

    #compare-nutrition-{{ section.id }} .compare-nutrition-blocks {
      width: 100%;
    }

    .compare-heading p {
      color: {{ section.settings.heading_color_mobile }};
      text-align: center;
      font-family: "League Spartan";
      font-size: 44px;
      font-style: normal;
      font-weight: 600;
      line-height: normal;
      text-transform: uppercase;
    }

    .compare-heading p strong {
      color: {{ section.settings.heading_accent_color_mobile }};
      font-family: "Roboto Condensed";
      font-size: 36px;
      font-style: normal;
      font-weight: 700;
      line-height: 36px;
      text-transform: uppercase;
    }

    .compare-description {
      color: {{ section.settings.description_color_mobile }};
      text-align: center;
      font-size: 16px;
      font-style: normal;
      font-weight: 500;
      line-height: 22px;
      margin-bottom: 16px;
    }

    .compare-nutrition-block {
      flex-direction: column;
      gap: 12px;
    }

    .compare-block-title strong {
      font-family: Outfit;
      font-weight: 700;
      font-style: Bold;
      font-size: 12px;
      leading-trim: NONE;
      line-height: 100%;
      letter-spacing: 1%;
      text-align: center;
    }

    .compare-block-title p {
      font-family: Outfit !important;
      font-weight: 300;
      font-style: Light;
      font-size: 12px;
      leading-trim: NONE;
      line-height: 100%;
      letter-spacing: 1%;
      text-align: center;
    }

    .compare-blocks {
      width: 100%;
      margin: 0 0 24px;
    }

    .try-btn {
      line-height: normal;
      font-size: 16px;
      font-style: normal;
      font-weight: 500;
      max-width: 192px;
      width: 100%;
      margin: 0 auto;
    }

    .mj-baner-btn-wrap {
      width: 100%;
    }
  }
{% endstyle %}

{%- liquid
  assign bg_alt = section.settings.bg_image_desktop.alt
  if bg_alt == blank
    assign bg_alt = section.settings.heading | strip_html | strip
  endif
  if bg_alt == blank
    assign bg_alt = 'Decorative banner background'
  endif
-%}

<section
  id="compare-nutrition-{{ section.id }}"
  class="compare-nutrition-section fade-up {% if section.settings.enable_about %}about_pt_main{% endif %}"
  {% if section.settings.bg_image_desktop != blank or section.settings.bg_image_mobile != blank %}
    aria-label="{{ bg_alt | escape }}"
  {% endif %}
>
  <div class="page-width">
    <div class="compare-nutrition-wrapper">
      <div class="compare-content">
        {% if section.settings.heading != blank %}
          <div
            class="compare-heading"
            data-animate
            role="heading"
            aria-level="2"
          >
            {{ section.settings.heading }}
          </div>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="compare-description" data-animate="left">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>

      <div class="mj-baner-btn-wrap">
        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a
            href="{{ section.settings.button_link }}"
            class="try-btn"
            role="button"
            aria-label="{{ section.settings.button_label | escape }}"
          >
            {{ section.settings.button_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>
    <div class="video-overlay" aria-hidden="true"></div>
  </div>
</section>

{% schema %}
{
  "name": "Home Banner Section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_about",
      "label": "Enable About Banner"
    },
    {
      "type": "header",
      "content": "Background Images"
    },
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Desktop Text Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_accent_color",
      "label": "Heading Accent Color (Strong/Bold text)",
      "default": "#AB8D3F"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color_about",
      "label": "Heading Color (About Page)",
      "default": "#F0E9D3"
    },
    {
      "type": "color",
      "id": "description_color_about",
      "label": "Description Color (About Page)",
      "default": "#F0E9D3"
    },
    {
      "type": "header",
      "content": "Mobile Text Colors"
    },
    {
      "type": "color",
      "id": "heading_color_mobile",
      "label": "Heading Color (Mobile)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_accent_color_mobile",
      "label": "Heading Accent Color (Mobile)",
      "default": "#AB8D3F"
    },
    {
      "type": "color",
      "id": "description_color_mobile",
      "label": "Description Color (Mobile)",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#8C7A6E"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFF6E8"
    },
    {
      "type": "color",
      "id": "button_bg_color_hover",
      "label": "Button Background Color (Hover)",
      "default": "#6B5B4C"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 100,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Home Banner Section"
    }
  ]
}
{% endschema %}