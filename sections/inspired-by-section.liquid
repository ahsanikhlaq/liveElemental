  @keyframes bounce-up {
    0% {
      transform: translateY(20px);
      opacity: 0;
    }
    50% {
      transform: translateY(-10px);
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .bounce-up {
    opacity: 0;
    transform: translateY(30px); /* Initial position */
  }

  .bounce-up.visible {
    animation: bounce-up 1s ease-out forwards;
  }

