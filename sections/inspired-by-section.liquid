<section class="section-{{ section.id }}-padding fade-up">
  <div class="page-width">
    <div class="inspired_main_container">
      <div class="inspired_left_content_wrap">
        <div class="inspired_main_head">{{ section.settings['feature-main-heading'] }}</div>
        <div class="inspired_feature_lists">
          {% for block in section.blocks %}
            <div class="insp_icon_main">
              <div class="insp_features_content">
                <div class="insp_list_heading">{{ block.settings['features-heading'] }}</div>
                <div class="insp_list_desc">{{ block.settings['features-description'] }}</div>
              </div>
            </div>
          {% endfor %}
          <div class="insp_shop_btn">
            <a class="insp-main-btn" href="{{ section.settings.insp_btn_link }}">{{ section.settings.insp_label_btn }} </a>
          </div>
        </div>
      </div>
      <div class="insp_right_feature_wrap">
        <div class="insp_main_img">
          {% if section.settings['video-main'] != blank %}
            <div class="video-wrapper-feature">
              {{
                section.settings['video-main']
                | video_tag:
                  class: 'feature-vid',
                  image_size: '1100x',
                  controls: false,
                  muted: true,
                  autoplay: true,
                  loop: true,
                  playsinline: true,
                  id: 'video-main'
              }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% comment %} <script>
  window.addEventListener('scroll', function () {
    const sections = document.querySelectorAll('.bounce-up');
    const windowHeight = window.innerHeight;

    sections.forEach((section) => {
      const sectionTop = section.getBoundingClientRect().top;

      // Check if the section is in view
      if (sectionTop < windowHeight - 100) {
        section.classList.add('visible');
      }
    });
  });
</script> {% endcomment %}

{% schema %}
{
  "name": "Inspired By Section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back-color",
      "label": "Background Color"
    },
    {
      "type": "richtext",
      "id": "feature-main-heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "insp_label_btn",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "insp_btn_link",
      "label": "Button Link"
    },
    {
      "type": "video",
      "id": "video-main",
      "label": "Video"
    },
  ],
  "blocks": [
    {
      "type": "blocks",
      "name": "Add Block",
      "settings": [
        {
          "type": "richtext",
          "id": "features-heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "features-description",
          "label": "Features Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inspired By Section"
    }
  ]
}
{% endschema %}
