<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.back_color }};
  }
  .col-main-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 40px;
  }
  .csym-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(185deg, rgba(0, 0, 0, 0.00) 3.35%, rgba(0, 0, 0, 0.65) 95.99%);
    z-index: 1;
    pointer-events: none;
    display: block !important;
  }
  .block-col-main {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 12px;
  }
  .sh-block-container {
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .sh-block-container a {
    display: block;
    position: relative;
  }
  .sh-block-container a:focus-visible {
    outline: 2px solid #fff;
    outline-offset: -2px;
  }
  .sh_block_icon {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.4s ease;
  }
  .sh-block-container:hover .sh_block_icon,
  .sh-block-container a:focus-visible .sh_block_icon {
    transform: scale(1.1);
  }
  .sh_block_btn {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translate(-50%, -50%);
    color: var(--White, #FFF);
    text-align: center;
    font-family: "League Spartan";
    font-size: 24px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 2;
  }
  .main-head-col {
    color: #000;
    text-align: center;
    font-family: "League Spartan";
    font-size: 36px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.mbl_padding_top }}px;
      padding-bottom: {{ section.settings.mbl_padding_bottom }}px;
    }
    .block-col-main {
      grid-template-columns: 1fr 1fr;
      gap: 6px;
    }
    .col-main-container {
      gap: 14px;
    }
    .main-head-col {
      font-size: 28px;
    }
    .sh_block_btn {
      font-size: 20px;
    }
    .sh_block_icon {
      object-fit: cover;
      height: 276px !important;
    }
  }
</style>

<section
  class="section-{{ section.id }}-padding fade-up"
  {% if section.settings.col_main_head != blank %}
    aria-labelledby="col-main-head-{{ section.id }}"
  {% endif %}
>
  <div class="page-width">
    <div class="col-main-container">
      {% if section.settings.col_main_head != blank %}
        <h2 id="col-main-head-{{ section.id }}" class="main-head-col">
          {{ section.settings.col_main_head | escape }}
        </h2>
      {% endif %}

      <div class="block-col-main" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign sh_label = block.settings.sh_button_label | default: 'Shop collection' | strip
            assign sh_link = block.settings.sh_button_link | default: '#'
            assign sh_image = block.settings.sh_block_icon
          -%}

          <div class="sh-block-container" role="listitem" {{ block.shopify_attributes }}>
            <a
              href="{{ sh_link }}"
              aria-label="{{ sh_label | escape }}"
            >
              {% if sh_image != blank %}
                {{
                  sh_image
                  | image_url: width: 800
                  | image_tag:
                    class: 'sh_block_icon',
                    loading: 'lazy',
                    widths: '300, 400, 600, 800, 1000',
                    sizes: '(max-width: 768px) 50vw, 25vw',
                    alt: sh_label
                }}
              {% else %}
                <div
                  class="sh_block_icon"
                  role="img"
                  aria-label="{{ sh_label | escape }}"
                  style="background:#eee;aspect-ratio:1/1;"
                ></div>
              {% endif %}

              {% if block.settings.sh_button_label != blank %}
                <span class="sh_block_btn" aria-hidden="true">
                  {{ block.settings.sh_button_label | escape }}
                </span>
              {% endif %}
            </a>
            <div class="csym-bg-overlay" aria-hidden="true"></div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Grid Home",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 10
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 10
    },
    {
      "type": "color",
      "id": "back_color",
      "label": "Background Color"
    },
    {
      "type": "text",
      "id": "col_main_head",
      "label": "Main Heading"
    }
  ],
  "presets": [
    {
      "name": "Collection Grid Home"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "block",
      "settings": [
        {
          "type": "image_picker",
          "id": "sh_block_icon",
          "label": "Collection Image"
        },
        {
          "type": "text",
          "id": "sh_button_label",
          "label": "Collection Label"
        },
        {
          "type": "url",
          "id": "sh_button_link",
          "label": "Button Link"
        }
      ]
    }
  ]
}
{% endschema %}