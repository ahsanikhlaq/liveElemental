{% style %}
  .privacy-menu-list {
    display: flex;
    gap: 20px;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }

  .privacy-menu-link {
    color: rgba(255, 255, 255, 0.70);
    font-family: Quicksand;
    font-size: 14px;
    font-weight: 400;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .privacy-menu-link:hover {
    color: #FFFFFF;
  }

  @media screen and (max-width: 768px) {
    .privacy-menu-list {
      gap: 10px;
      justify-content:center;
    }
    .privacy-menu-link {
      font-size: 12px;
    }
  }
    .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
        background:{{section.settings.bg_color}};
    }
    .sc_log{
        width: 497.333px;
    /* height: 53.333px; */
    display:block;
    }
    .cs_footer_content-wrap{
        display:flex;
        flex-direction:column;
        gap:30px;
    }
    /* Make link relative and remove default underline */
  .footer-link-menu .cs_footer_menu_list {
    position: relative;
    text-decoration: none;
  }

  /* Underline using ::after */
  .footer-link-menu .cs_footer_menu_list::after {
    content: '';
    position: absolute;
    bottom: -5px; /* space below text */
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #FFFFFF;
    transform: scaleX(0);
    transform-origin: bottom right;
    transition: transform 0.3s ease-in-out;
  }

  /* Hover animation */
  .footer-link-menu .cs_footer_menu_list:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }


