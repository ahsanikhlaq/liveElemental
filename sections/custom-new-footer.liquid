<section class="section-{{ section.id }}-padding cs-banner-parent fade-up">
  <div class="page-width">
    <div class="cs_footer_main">
      <!-- TOP CONTENT -->
      <div class="cs_footer_main_top">
        <!-- LOGO + TEXT (FADE DESKTOP / SLIDE MOBILE) -->
        <div
          class="cs_footer_content-wrap scroll-trigger animate--fade-in"
          data-animate
        >
          <div class="cs-foter-logo">
            <img
              class="sc_log"
              src="{{ section.settings.sc_logo | image_url }}"
              width="100%"
              height="auto"
              loading="lazy"
            >
          </div>
          <div class="singg">
            {% render 'email-signup' %}
          </div>
          <div class="cs_text_foter">
            {{ section.settings.sc_foter_txt }}
          </div>
        </div>

        <!-- MENUS -->
        <div class="cs_footer_menus">
          <div class="footer-links-field">
            {% for block in section.blocks %}
              <!-- EACH COLUMN = AUTO STAGGER -->
              <div
                class="footer-links-cata scroll-trigger animate--slide-up"
                data-animate
                {{ block.shopify_attributes }}
              >
                <div class="footer-links-top">
                  <h2 class="links-heading">
                    {{ block.settings['footer-menu-heading'] }}
                  </h2>
                  <span class="footer-link-expand">
                    <!-- icon unchanged -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                      <path d="M17.5 10C17.5 10.1658 17.4342 10.3247 17.3169 10.4419C17.1997 10.5592 17.0408 10.625 16.875 10.625H10.625V16.875C10.625 17.0408 10.5592 17.1997 10.4419 17.3169C10.3247 17.4342 10.1658 17.5 10 17.5C9.83424 17.5 9.67527 17.4342 9.55806 17.3169C9.44085 17.1997 9.375 17.0408 9.375 16.875V10.625H3.125C2.95924 10.625 2.80027 10.5592 2.68306 10.4419C2.56585 10.3247 2.5 10.1658 2.5 10C2.5 9.83424 2.56585 9.67527 2.68306 9.55806C2.80027 9.44085 2.95924 9.375 3.125 9.375H9.375V3.125C9.375 2.95924 9.44085 2.80027 9.55806 2.68306C9.67527 2.56585 9.83424 2.5 10 2.5C10.1658 2.5 10.3247 2.56585 10.4419 2.68306C10.5592 2.80027 10.625 2.95924 10.625 3.125V9.375H16.875C17.0408 9.375 17.1997 9.44085 17.3169 9.55806C17.4342 9.67527 17.5 9.83424 17.5 10Z" fill="white"></path>
                    </svg>
                  </span>
                </div>

                <div class="footer-links">
                  <ul class="footer-link-menu">
                    {% if block.settings.menu != blank %}
                      {% for link in block.settings.menu.links %}
                        <li>
                          <a
                            href="{{ link.url }}"
                            class="cs_footer_menu_list link link--text list-menu_item list-menuitem--link{% if link.active %} list-menu_item--active{% endif %}"
                          >
                            {{ link.title | escape }}
                          </a>
                        </li>
                      {% endfor %}
                    {% endif %}
                  </ul>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <!-- BOTTOM BAR -->
      <div
        class="cs_footer_bottom_contet scroll-trigger animate--fade-in"
        data-animate
      >
        <div class="cs_footer_content-left">{{ 'now' | date: '%Y' }} Copyright - All Rights Reserved</div>

        <div class="foter-privacy-menu">
          {% if section.settings.privacy_menu != blank %}
            <ul class="privacy-menu-list">
              {% for link in section.settings.privacy_menu.links %}
                <li>
                  <a href="{{ link.url }}" class="privacy-menu-link">
                    {{ link.title | escape }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
        <div class="fotr-icon-wrap">
          <div class="social-media-icons social-media-icons_desktop">
            <a class="cs_socal_icons" href="{{ section.settings.fb_url }}">
              {% render 'cs_socal_icon_fb' %}
            </a>
            <a class="cs_socal_icons" href="{{ section.settings.insta_url }}">
              {% render 'cs_socal_icon_inst' %}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Footer Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "sc_logo",
      "label": "Footer Logo"
    },
    {
      "type": "richtext",
      "id": "sc_foter_txt",
      "label": "Footer Content"
    },
    {
      "type": "text",
      "id": "follow-heading",
      "label": "Socal Icon Heading"
    },
    {
      "type": "url",
      "id": "fb_url",
      "label": "FB Url"
    },
    {
      "type": "url",
      "id": "insta_url",
      "label": "Insta Url"
    },
    {
      "type": "url",
      "id": "pint_url",
      "label": "Pintrst Url"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "Tiktok Url"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "label": "padding_top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "label": "padding_bottom",
      "default": 30
    },
    {
      "type": "range",
      "id": "mbl_padding_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top Padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "mbl_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom Padding",
      "default": 30
    },
    {
      "type": "image_picker",
      "id": "payment_icon",
      "label": "Payment Icon"
    },
    {
      "type": "link_list",
      "id": "privacy_menu",
      "label": "Privacy Menu"
    }
  ],
  "blocks": [
    {
      "type": "add",
      "name": "Add Tab",
      "settings": [
        {
          "type": "text",
          "id": "footer-menu-heading",
          "label": "Menu Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer Section"
    }
  ]
}
{% endschema %}
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const footerLinks = document.querySelectorAll('.footer-link-menu');
    const footerToggles = document.querySelectorAll('.footer-links-top');

    function setMinusIcon(icon) {
      icon.innerHTML = `<svg width="19" height="2" viewBox="0 0 19 2" fill="none" xmlns="http://www.w3.org/2000/svg" data-acsb-clickable="true" data-acsb-navigable="true" data-acsb-now-navigable="false" data-acsb-hidden="true" aria-hidden="true">
                        <path d="M1 1H17.8" stroke="#ffff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>`;
    }

    function setPlusIcon(icon) {
      icon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
  <path d="M17.5 10C17.5 10.1658 17.4342 10.3247 17.3169 10.4419C17.1997 10.5592 17.0408 10.625 16.875 10.625H10.625V16.875C10.625 17.0408 10.5592 17.1997 10.4419 17.3169C10.3247 17.4342 10.1658 17.5 10 17.5C9.83424 17.5 9.67527 17.4342 9.55806 17.3169C9.44085 17.1997 9.375 17.0408 9.375 16.875V10.625H3.125C2.95924 10.625 2.80027 10.5592 2.68306 10.4419C2.56585 10.3247 2.5 10.1658 2.5 10C2.5 9.83424 2.56585 9.67527 2.68306 9.55806C2.80027 9.44085 2.95924 9.375 3.125 9.375H9.375V3.125C9.375 2.95924 9.44085 2.80027 9.55806 2.68306C9.67527 2.56585 9.83424 2.5 10 2.5C10.1658 2.5 10.3247 2.56585 10.4419 2.68306C10.5592 2.80027 10.625 2.95924 10.625 3.125V9.375H16.875C17.0408 9.375 17.1997 9.44085 17.3169 9.55806C17.4342 9.67527 17.5 9.83424 17.5 10Z" fill="white"/>
</svg>`;
    }

    footerToggles.forEach((toggle, index) => {
      toggle.addEventListener('click', function () {
        // Mobile only: max-width 768px
        if (window.innerWidth > 768) return;

        footerLinks.forEach((sub, subIndex) => {
          if (subIndex !== index) {
            sub.classList.remove('Linlexpanded');
            sub.style.maxHeight = '0px';
            const otherIcon = footerToggles[subIndex].querySelector('.footer-link-expand');
            if (otherIcon) setPlusIcon(otherIcon);
          }
        });

        const icon = toggle.querySelector('.footer-link-expand');
        const currentMenu = footerLinks[index];

        if (currentMenu.classList.contains('Linlexpanded')) {
          currentMenu.classList.remove('Linlexpanded');
          currentMenu.style.maxHeight = '0px';
          if (icon) setPlusIcon(icon);
        } else {
          currentMenu.classList.add('Linlexpanded');
          currentMenu.style.maxHeight = 'fit-content';
          if (icon) setMinusIcon(icon);
        }
      });
    });
  });
</script>
