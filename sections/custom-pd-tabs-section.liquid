<style>
  .custom-tabs {
    background: #FFFFFF;
    padding: 80px 30px;
  }
  .custom-tabs .custom-tabs-title p {
    margin: 0;
  }
  .custom-tabs .custom-tabs-title {
    margin: 0 auto 40px;
    text-align: center;
    max-width: 800px;
    width: 100%;
    color: #000;
    font-size: 35px;
    line-height: 1.2;
    text-transform: uppercase;
    font-weight: 700;
    font-family: "League Spartan", sans-serif;
  }
  .cards-grid-inner-mbl {
    {% comment %} display: none; {% endcomment %}
}
.cards-grid-inner{
display:block;
}
  .custom-tabs .custom-tabs-wrapper {
    display: flex;
    gap: 24px;
  }
  /* Tab Navigation Sidebar */
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper {
    display: flex;
    gap: 0;
    width: 22%;
    margin-bottom: 0;
    flex-direction: column;
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item {
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    display: flex;
    padding: 16px 24px;
    justify-content: center;
    align-items: flex-start;
    gap: 8px;
    align-self: stretch;
    background: var(--Main-beige, #F0E9D3);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.10), 0 2px 4px -2px rgba(0, 0, 0, 0.10);
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item:last-child {
    border-right: none;
  }
  .custom-tabs .tab-cc-icon {
    width: 20px;
    height: 20px;
    display: block;
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item.active {
    background: #8C7A6E;
  }
  .custom-tabs .name p {
    margin: 0;
    color: #333;
    font-family: "League Spartan", sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 600;
    line-height: 24px;
    {% comment %} text-transform: uppercase; {% endcomment %}
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item.active .name p {
    color: #FFFFFF;
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item .tab-cc-icon {
    filter: brightness(0);
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item.active .tab-cc-icon {
    filter: invert(1);
  }
  /* Display Wrapper */
  .custom-tabs .custom-tabs-wrapper-display-wrapper {
    background: #FFF;
    box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.25);
    display: flex;
    padding: 30px 24px;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    width: 78%;
  }

  /* Tab Heading Inside Grid */

  .custom-tabs .tab-inner-heading-title {
    color: #152728;
    font-family: "League Spartan";
    font-size: 28px;
    font-weight: 600;
    margin: 0 0 16px 0;
    text-transform: capitalize;
  }
  .custom-tabs .tab-inner-heading-desc {
    color: #333;
    font-family: Quicksand;
    font-size: 16px;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
  }

  /* Product & Process Grids */
  .product-cards-grid,
  .process-cards-grid {
    display: none;
    width: 100%;
    flex-direction: column;
  }
  .product-cards-grid.active,
  .process-cards-grid.active {
    display: flex;
  }
.custom-tabs .tab-inner-heading-title {
    color: #0A0A0A;
    font-family: "League Spartan";
    font-size: 36px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
    text-align: left;
    padding-bottom: 16px;
}


  /* Stats Grid Styles */
  .custom-tabs .stats-grid {
    width: 100%;
    margin-top: 24px;
    background: var(--teal, #00727F);
    display: flex;
    flex-direction: column;
    padding: 30px;
    gap: 24px;
    align-self: stretch;
  }
.custom-tabs .stat-block-wrap {
    display: flex;
    gap: 100px;
    overflow:hidden;
}
.custom-tabs .stat-head {
    color: var(--White, #FFF);
    font-family: "League Spartan";
    font-size: 28px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    letter-spacing: -0.28px;
    text-transform: uppercase;
}
  .custom-tabs .stat-item {
    {% comment %} text-align: center;
    padding: 20px; {% endcomment %}
  }

  .custom-tabs .stat-percentage {
    color: var(--White, #FFF);
text-align: center;
font-family: "League Spartan";
font-size: 48px;
font-style: normal;
font-weight: 400;
line-height: normal;
  }

  .custom-tabs .stat-description {
    color: var(--White, #FFF);

/* Body/Medium/16 */
font-family: Quicksand;
font-size: 16px;
font-style: normal;
font-weight: 500;
line-height: 22px; /* 137.5% */
    margin: 0;
  }

  /* Process Grid */
  .process-cards-grid .cards-grid-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    width: 100%;
  }

  /* Rest of your existing styles remain exactly the same */
  .custom-tabs .process-card {
    text-align: center;
    border-radius: 1px;
    background: #F7F7F7;
    display: flex;
    padding: 16px;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .custom-tabs .process-icon {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
  .custom-tabs .process-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .custom-tabs .process-step {
    font-family: "League Spartan";
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--almond-forest, #8C7A6E);
    font-size: 14px;
    font-weight: 500;
    border: 1px solid var(--almond-forest, #8C7A6E);
    background: rgba(140, 156, 110, 0.05);
    padding: 5px 12px 3px;
    margin-bottom: 8px;
  }
  .custom-tabs .process-title {
    color: var(--Black, #152728);
    font-family: "League Spartan";
    font-size: 20px;
    font-weight: 500;
    margin: 16px 0 4px;
    text-transform: capitalize;
  }
  .custom-tabs .process-desc {
    color: var(--Black, #152728);
    font-family: Quicksand;
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    margin: 0;
  }

  .custom-tabs .product-card {
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }
  .custom-tabs .product-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }
  .custom-tabs .product-card-image img{
    width: 100%;
    height: 329px;
    object-fit: cover;
  }
  .custom-tabs .product-card-content {
    padding: 30px 8px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .custom-tabs .product-card-title {
    color: var(--Black, #171717);
    border-bottom: 1px solid var(--Grey, #797979);
    padding-bottom: 8px;
    font-family: "League Spartan";
    font-size: 20px;
    font-weight: 600;
    margin: 0;
    text-transform: capitalize;
  }
  .custom-tabs .product-card-features {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .custom-tabs .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    flex-direction: column;
  }
  .custom-tabs .feature-icon {
    width: 20px;
    height: 20px;
  }
  .custom-tabs .feature-label {
    color: var(--Black, #171717);
    font-family: "League Spartan";
    font-size: 18px;
    font-weight: 500;
    text-transform: capitalize;
  }
  .custom-tabs .feature-text {
    color: var(--Black, #171717);
    font-family: Quicksand;
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    margin: 0;
  }
  .custom-tabs .feature-content {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  /* Product Cards Grid */
 .product-cards-grid .cards-grid-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    width: 100%;
  }

  /* Mobile */
  @media screen and (max-width: 1024px) {
    .product-cards-grid .cards-grid-inner,
    .process-cards-grid .cards-grid-inner,
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
