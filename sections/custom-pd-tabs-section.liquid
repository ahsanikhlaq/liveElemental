        font-weight: 500;
        line-height: normal;
        margin:0;
      }
    .custom-tabs .process-card-mbl{
    max-width: 89%;
    min-width: 89%;
    }
    .custom-tabs .stat-block-wrap {
    gap: 12px;
    overflow:hidden;
}
    .custom-tabs .custom-tabs-title {
      font-size: 24px;
      margin-bottom: 25px;
    }
    .custom-tabs .custom-tabs-wrapper {
