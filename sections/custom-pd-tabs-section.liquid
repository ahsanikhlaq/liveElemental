<style>
  .custom-tabs {
    background: #FFFFFF;
    padding: 80px 30px;
  }
  .custom-tabs .custom-tabs-title { margin: 0; }
  .custom-tabs .custom-tabs-title-wrapper {
    margin: 0 auto 40px;
    text-align: center;
    max-width: 800px;
    width: 100%;
    color: #000;
    font-size: 35px;
    line-height: 1.2;
    text-transform: uppercase;
    font-weight: 700;
    font-family: "League Spartan", sans-serif;
  }
  .custom-tabs .custom-tabs-title-wrapper p { margin: 0; }

  .cards-grid-inner-mbl { /* unchanged */ }
  .cards-grid-inner { display: block; }

  .custom-tabs .custom-tabs-wrapper { display: flex; gap: 24px; }

  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper {
    display: flex;
    gap: 0;
    width: 22%;
    margin-bottom: 0;
    flex-direction: column;
  }

  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item {
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    display: flex;
    padding: 16px 24px;
    justify-content: center;
    align-items: flex-start;
    gap: 8px;
    align-self: stretch;
    background: var(--Main-beige, #F0E9D3);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.10), 0 2px 4px -2px rgba(0, 0, 0, 0.10);
    border: 0;
    width: 100%;
    text-align: left;
    font: inherit;
    color: inherit;
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item:focus-visible {
    outline: 2px solid #8C7A6E;
    outline-offset: -2px;
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item:last-child { border-right: none; }

  .custom-tabs .tab-cc-icon { width: 20px; height: 20px; display: block; }
  .custom-tabs .tab-cc-icon img { width: 100%; height: 100%; object-fit: contain; }

  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item[aria-selected="true"] {
    background: #8C7A6E;
  }
  .custom-tabs .name p {
    margin: 0;
    color: #333;
    font-family: "League Spartan", sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 24px;
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item[aria-selected="true"] .name p {
    color: #FFFFFF;
  }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item .tab-cc-icon img { filter: brightness(0); }
  .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item[aria-selected="true"] .tab-cc-icon img { filter: invert(1); }

  .custom-tabs .custom-tabs-wrapper-display-wrapper {
    background: #FFF;
    box-shadow: 0 4px 4px 0 rgba(0, 0, 0, 0.25);
    display: flex;
    padding: 30px 24px;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    width: 78%;
  }

  .custom-tabs .tab-inner-heading-title {
    color: #0A0A0A;
    font-family: "League Spartan";
    font-size: 36px;
    font-weight: 600;
    line-height: normal;
    text-transform: uppercase;
    text-align: left;
    padding-bottom: 16px;
    margin: 0 0 16px 0;
  }
  .custom-tabs .tab-inner-heading-desc {
    color: #333;
    font-family: Quicksand;
    font-size: 16px;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
  }

  .product-cards-grid,
  .process-cards-grid {
    width: 100%;
    flex-direction: column;
  }
  /* Use [hidden] instead of .active toggle so AT respects panel visibility */
  [role="tabpanel"][hidden] { display: none !important; }
  [role="tabpanel"]:not([hidden]) { display: flex; }
  [role="tabpanel"]:focus-visible { outline: 2px solid #8C7A6E; outline-offset: 2px; }

  .custom-tabs .stats-grid {
    width: 100%;
    margin-top: 24px;
    background: var(--teal, #00727F);
    display: flex;
    flex-direction: column;
    padding: 30px;
    gap: 24px;
    align-self: stretch;
  }
  .custom-tabs .stat-block-wrap { display: flex; gap: 100px; overflow: hidden; }
  .custom-tabs .stat-head {
    color: var(--White, #FFF);
    font-family: "League Spartan";
    font-size: 28px;
    font-weight: 500;
    line-height: normal;
    letter-spacing: -0.28px;
    text-transform: uppercase;
  }
  .custom-tabs .stat-percentage {
    color: var(--White, #FFF);
    text-align: center;
    font-family: "League Spartan";
    font-size: 48px;
    font-weight: 400;
  }
  .custom-tabs .stat-description {
    color: var(--White, #FFF);
    font-family: Quicksand;
    font-size: 16px;
    font-weight: 500;
    line-height: 22px;
    margin: 0;
  }

  .process-cards-grid .cards-grid-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    width: 100%;
  }

  .custom-tabs .process-card {
    text-align: center;
    border-radius: 1px;
    background: #F7F7F7;
    display: flex;
    padding: 16px;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .custom-tabs .process-icon {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
  .custom-tabs .process-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .custom-tabs .process-step {
    font-family: "League Spartan";
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--almond-forest, #8C7A6E);
    font-size: 14px;
    font-weight: 500;
    border: 1px solid var(--almond-forest, #8C7A6E);
    background: rgba(140, 156, 110, 0.05);
    padding: 5px 12px 3px;
    margin-bottom: 8px;
  }
  .custom-tabs .process-title {
    color: var(--Black, #152728);
    font-family: "League Spartan";
    font-size: 20px;
    font-weight: 500;
    margin: 16px 0 4px;
    text-transform: capitalize;
  }
  .custom-tabs .process-desc {
    color: var(--Black, #152728);
    font-family: Quicksand;
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    margin: 0;
  }

  .custom-tabs .product-card {
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }
  .custom-tabs .product-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1); }
  .custom-tabs .product-card-image img { width: 100%; height: 329px; object-fit: cover; }
  .custom-tabs .product-card-content {
    padding: 30px 8px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .custom-tabs .product-card-title {
    color: var(--Black, #171717);
    border-bottom: 1px solid var(--Grey, #797979);
    padding-bottom: 8px;
    font-family: "League Spartan";
    font-size: 20px;
    font-weight: 600;
    margin: 0;
    text-transform: capitalize;
  }
  .custom-tabs .product-card-features { display: flex; flex-direction: column; gap: 12px; }
  .custom-tabs .feature-item { display: flex; align-items: flex-start; gap: 10px; flex-direction: column; }
  .custom-tabs .feature-icon { width: 20px; height: 20px; }
  .custom-tabs .feature-icon img { width: 100%; height: 100%; object-fit: contain; }
  .custom-tabs .feature-label {
    color: var(--Black, #171717);
    font-family: "League Spartan";
    font-size: 18px;
    font-weight: 500;
    text-transform: capitalize;
  }
  .custom-tabs .feature-text {
    color: var(--Black, #171717);
    font-family: Quicksand;
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    margin: 0;
  }
  .custom-tabs .feature-content { display: flex; align-items: center; gap: 5px; }

  .product-cards-grid .cards-grid-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    width: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .custom-tabs .product-card,
    .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item {
      transition: none !important;
    }
    .custom-tabs .product-card:hover { transform: none; }
  }

  @media screen and (max-width: 1024px) {
    .product-cards-grid .cards-grid-inner,
    .process-cards-grid .cards-grid-inner,
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }
  }
  @media screen and (max-width: 768px) {
    .custom-tabs .product-card { width: 100%; max-width: 100%; min-width: 80%; }
    .custom-tabs .process-icon img {
      max-width: 38px; max-height: 38px; min-height: 38px; min-width: 38px;
    }
    .pd_card_wrap {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
    }
    .custom-tabs .stat-head { font-size: 24px; }
    .custom-tabs .process-desc { text-align: left; }
    .custom-tabs .product-card-mbl { width: 100%; max-width: 100%; min-width: 90%; }
    .cards-grid-inner-mbl {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
      overflow: auto;
    }
    .custom-tabs { padding: 25px 10px 25px 10px; }
    .custom-tabs .process-card {
      max-width: 100%;
      min-width: 100%;
      flex-direction: row;
      gap: 12px;
      padding: 12px;
    }
    .custom-tabs .process-step {
      margin-bottom: 12px;
      padding: 6px 12px 4px 12px;
      font-size: 12px;
    }
    .custom-tabs .process-title {
      padding-bottom: 6px;
      font-size: 18px;
      font-weight: 500;
      line-height: normal;
      margin: 0;
    }
    .custom-tabs .process-card-mbl { max-width: 89%; min-width: 89%; }
    .custom-tabs .stat-block-wrap { gap: 12px; overflow: hidden; }
    .custom-tabs .custom-tabs-title-wrapper { font-size: 24px; margin-bottom: 25px; }
    .custom-tabs .custom-tabs-wrapper { flex-direction: column; }
    .custom-tabs .custom-tabs-wrapper-ingredients-wrapper {
      width: 100%;
      flex-direction: row;
      padding-bottom: 16px;
    }
    .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item {
      border-right: none;
      border-bottom: 1px solid #ccc;
      padding: 15px 20px;
      flex: 1;
    }
    .custom-tabs .custom-tabs-wrapper-ingredients-wrapper-item:last-child { border-bottom: none; }
    .custom-tabs .custom-tabs-wrapper-display-wrapper {
      width: 100%;
      padding: 0;
      box-shadow: none;
    }
    .product-cards-grid .cards-grid-inner,
    .process-cards-grid .cards-grid-inner {
      gap: 12px;
      display: flex !important;
      overflow: auto;
    }
    .custom-tabs .stats-grid { grid-template-columns: 1fr; padding: 30px 10px; margin-top: 46px; }
    .custom-tabs .product-card-image img { height: 300px; }
    .custom-tabs .product-card-content { padding: 20px 15px; }
    .custom-tabs .tab-inner-heading-title { font-size: 24px; padding-bottom: 22px; }
    .custom-tabs .tab-inner-heading-desc { font-size: 14px; }
    .custom-tabs .stat-percentage { font-size: 32px; }
    .custom-tabs .stat-description { font-size: 12px; line-height: normal; }
  }
</style>

{%- liquid
  assign title_plain = section.settings['r-title'] | strip_html | strip
-%}

<section
  class="custom-tabs"
  {% if title_plain != blank %}
    aria-labelledby="custom-tabs-title-{{ section.id }}"
  {% endif %}
>
  <div class="page-width">
    {% if section.settings['r-title'] != blank %}
      <h2 id="custom-tabs-title-{{ section.id }}" class="custom-tabs-title-wrapper">
        <span class="custom-tabs-title">{{ section.settings['r-title'] }}</span>
      </h2>
    {% endif %}

    <div class="custom-tabs-wrapper">

      <div
        class="custom-tabs-wrapper-ingredients-wrapper"
        role="tablist"
        aria-label="{{ title_plain | default: 'Sections' | escape }}"
      >
        {%- assign first_tab_rendered = false -%}
        {%- assign tab_index = 0 -%}
        {% for block in section.blocks %}
          {% if block.type == 'tab-heading-block' %}
            {%- liquid
              assign tab_id = block.settings['t-ingredient-id']
              assign tab_name_plain = block.settings['r-ingredient-name'] | strip_html | strip
              if tab_name_plain == blank
                assign tab_name_plain = 'Tab ' | append: forloop.index
              endif
              assign is_selected = false
              unless first_tab_rendered
                assign is_selected = true
              endunless
              assign tab_index = tab_index | plus: 1
            -%}
            <button
              type="button"
              role="tab"
              id="ctab-{{ section.id }}-{{ tab_id }}"
              aria-controls="cpanel-{{ section.id }}-{{ tab_id }}"
              aria-selected="{{ is_selected }}"
              tabindex="{% if is_selected %}0{% else %}-1{% endif %}"
              class="custom-tabs-wrapper-ingredients-wrapper-item"
              data-id="tab-{{ tab_id }}"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.tab_cc_icon != blank %}
                <span class="tab-cc-icon">
                  {{
                    block.settings.tab_cc_icon
                    | image_url: width: 100
                    | image_tag:
                      widths: '20, 40, 60, 80, 100',
                      alt: '',
                      loading: 'eager',
                      width: 20,
                      height: 20
                  }}
                </span>
              {% endif %}
              {% if block.settings['r-ingredient-name'] != blank %}
                <span class="name">{{ block.settings['r-ingredient-name'] }}</span>
              {% else %}
                <span class="name"><p>{{ tab_name_plain | escape }}</p></span>
              {% endif %}
            </button>
            {%- assign first_tab_rendered = true -%}
          {% endif %}
        {% endfor %}
      </div>

      <div class="custom-tabs-wrapper-display-wrapper">
        {%- assign tab_ids = '' -%}
        {% for block in section.blocks %}
          {% if block.type == 'tab-heading-block' %}
            {%- assign tab_id = block.settings['t-ingredient-id'] -%}
            {% unless tab_ids contains tab_id %}
              {%- assign tab_ids = tab_ids | append: tab_id | append: ',' -%}
            {% endunless %}
          {% endif %}
        {% endfor %}
        {%- assign tab_array = tab_ids | split: ',' -%}
        {%- assign firstTab = true -%}

        {% for tab_id in tab_array %}
          {% if tab_id != blank %}
            {%- assign is_process_tab = false -%}
            {%- assign has_stats = false -%}
            {%- assign tab_name_for_panel = tab_id -%}

            {% for block in section.blocks %}
              {% if block.type == 'tab-heading-block' and block.settings['t-ingredient-id'] == tab_id %}
                {%- assign tab_name_for_panel = block.settings['r-ingredient-name'] | strip_html | strip | default: tab_id -%}
              {% endif %}
              {% if block.type == 'process-card-block' and block.settings['process-tab-id'] == tab_id %}
                {%- assign is_process_tab = true -%}
              {% endif %}
              {% if block.type == 'stats-block' and block.settings['stats-tab-id'] == tab_id %}
                {%- assign has_stats = true -%}
              {% endif %}
            {% endfor %}

            <div
              role="tabpanel"
              id="cpanel-{{ section.id }}-{{ tab_id }}"
              aria-labelledby="ctab-{{ section.id }}-{{ tab_id }}"
              tabindex="0"
              class="{% if is_process_tab %}process-cards-grid{% else %}product-cards-grid{% endif %}"
              data-content="tab-{{ tab_id }}"
              {% unless firstTab %}hidden{% endunless %}
            >
              {%- assign firstTab = false -%}

              {% for block in section.blocks %}
                {% if block.type == 'tab_heading_content' and block.settings.heading_tab_id == tab_id %}
                  <div class="tab-inner-heading">
                    {% if block.settings.heading_title != blank %}
                      <h3 class="tab-inner-heading-title">{{ block.settings.heading_title | escape }}</h3>
                    {% endif %}
                    {% if block.settings.heading_desc != blank %}
                      <div class="tab-inner-heading-desc">{{ block.settings.heading_desc }}</div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}

              <div class="cards-grid-inner" role="list">
                {% if is_process_tab %}

                  {% for block in section.blocks %}
                    {% if block.type == 'process-card-block' and block.settings['process-tab-id'] == tab_id %}
                      {%- liquid
                        assign p_title = block.settings['process-title'] | strip
                        if p_title == blank
                          assign p_title = 'Step ' | append: forloop.index
                        endif
                      -%}
                      <div class="process-card" role="listitem" {{ block.shopify_attributes }}>
                        {% if block.settings['process-icon'] != blank %}
                          <div class="process-icon">
                            {{
                              block.settings['process-icon']
                              | image_url: width: 200
                              | image_tag:
                                widths: '60, 120, 200',
                                alt: p_title,
                                loading: 'lazy',
                                width: 60,
                                height: 60
                            }}
                          </div>
                        {% endif %}
                        <div class="pd_card_wrap">
                          {% if block.settings['process-step'] != blank %}
                            <span class="process-step">{{ block.settings['process-step'] | escape }}</span>
                          {% endif %}
                          {% if block.settings['process-title'] != blank %}
                            <h4 class="process-title">{{ block.settings['process-title'] | escape }}</h4>
                          {% endif %}
                          {% if block.settings['process-desc'] != blank %}
                            <p class="process-desc">{{ block.settings['process-desc'] | escape | newline_to_br }}</p>
                          {% endif %}
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}

                {% else %}

                  {% for block in section.blocks %}
                    {% if block.type == 'product-card-block' and block.settings['card-tab-id'] == tab_id %}
                      {%- liquid
                        assign card_title = block.settings['card-title'] | strip
                        if card_title == blank
                          assign card_title = 'Fabric ' | append: forloop.index
                        endif
                        assign card_image_alt = block.settings['card-image'].alt | default: card_title
                      -%}
                      <div class="product-card" role="listitem" {{ block.shopify_attributes }}>
                        {% if block.settings['card-image'] != blank %}
                          <div class="product-card-image">
                            {{
                              block.settings['card-image']
                              | image_url: width: 1440
                              | image_tag:
                                widths: '300, 400, 600, 800, 1000, 1440',
                                sizes: '(max-width: 768px) 90vw, 33vw',
                                alt: card_image_alt,
                                loading: 'lazy'
                            }}
                          </div>
                        {% endif %}
                        <div class="product-card-content">
                          {% if block.settings['card-title'] != blank %}
                            <h4 class="product-card-title">{{ block.settings['card-title'] | escape }}</h4>
                          {% endif %}
                          <div class="product-card-features">

                            {% if block.settings['feature-look'] != blank %}
                              <div class="feature-item">
                                <div class="feature-content">
                                  {% if block.settings['icon-look'] != blank %}
                                    <div class="feature-icon">
                                      {{
                                        block.settings['icon-look']
                                        | image_url: width: 60
                                        | image_tag:
                                          widths: '20, 40, 60',
                                          alt: '',
                                          loading: 'lazy',
                                          width: 20,
                                          height: 20
                                      }}
                                    </div>
                                  {% endif %}
                                  <div class="feature-label">Look</div>
                                </div>
                                <p class="feature-text">{{ block.settings['feature-look'] | escape | newline_to_br }}</p>
                              </div>
                            {% endif %}

                            {% if block.settings['feature-feel'] != blank %}
                              <div class="feature-item">
                                <div class="feature-content">
                                  {% if block.settings['icon-feel'] != blank %}
                                    <div class="feature-icon">
                                      {{
                                        block.settings['icon-feel']
                                        | image_url: width: 60
                                        | image_tag:
                                          widths: '20, 40, 60',
                                          alt: '',
                                          loading: 'lazy',
                                          width: 20,
                                          height: 20
                                      }}
                                    </div>
                                  {% endif %}
                                  <div class="feature-label">Feel</div>
                                </div>
                                <p class="feature-text">{{ block.settings['feature-feel'] | escape | newline_to_br }}</p>
                              </div>
                            {% endif %}

                            {% if block.settings['feature-fabric'] != blank %}
                              <div class="feature-item">
                                <div class="feature-content">
                                  {% if block.settings['icon-fabric'] != blank %}
                                    <div class="feature-icon">
                                      {{
                                        block.settings['icon-fabric']
                                        | image_url: width: 60
                                        | image_tag:
                                          widths: '20, 40, 60',
                                          alt: '',
                                          loading: 'lazy',
                                          width: 20,
                                          height: 20
                                      }}
                                    </div>
                                  {% endif %}
                                  <div class="feature-label">Fabric Content</div>
                                </div>
                                <p class="feature-text">{{ block.settings['feature-fabric'] | escape | newline_to_br }}</p>
                              </div>
                            {% endif %}

                            {% if block.settings['feature-performance'] != blank %}
                              <div class="feature-item">
                                <div class="feature-content">
                                  {% if block.settings['icon-performance'] != blank %}
                                    <div class="feature-icon">
                                      {{
                                        block.settings['icon-performance']
                                        | image_url: width: 60
                                        | image_tag:
                                          widths: '20, 40, 60',
                                          alt: '',
                                          loading: 'lazy',
                                          width: 20,
                                          height: 20
                                      }}
                                    </div>
                                  {% endif %}
                                  <div class="feature-label">Performance</div>
                                </div>
                                <p class="feature-text">{{ block.settings['feature-performance'] | escape | newline_to_br }}</p>
                              </div>
                            {% endif %}

                          </div>
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}

                {% endif %}
              </div>

              {% if has_stats %}
                <div class="stats-grid">
                  {% if section.settings['stat-head'] != blank %}
                    <div class="stat-head">{{ section.settings['stat-head'] | escape }}</div>
                  {% endif %}
                  <div class="stat-block-wrap">
                    {% for block in section.blocks %}
                      {% if block.type == 'stats-block' and block.settings['stats-tab-id'] == tab_id %}
                        <div class="stat-item" {{ block.shopify_attributes }}>
                          <span class="stat-percentage">{{ block.settings['stat-percentage'] | escape }}</span>
                          <p class="stat-description">{{ block.settings['stat-description'] | escape | newline_to_br }}</p>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.getElementById('custom-tabs-title-{{ section.id }}')
      ? document.getElementById('custom-tabs-title-{{ section.id }}').closest('.custom-tabs')
      : document.querySelectorAll('.custom-tabs')[0];
    if (!section) return;

    var tabs = Array.prototype.slice.call(section.querySelectorAll('[role="tab"]'));
    var panels = Array.prototype.slice.call(section.querySelectorAll('[role="tabpanel"]'));
    if (!tabs.length) return;

    function activate(index, focus) {
      tabs.forEach(function (t, i) {
        var selected = i === index;
        t.setAttribute('aria-selected', selected ? 'true' : 'false');
        t.setAttribute('tabindex', selected ? '0' : '-1');
      });
      panels.forEach(function (p) { p.hidden = true; });

      var targetId = tabs[index].getAttribute('aria-controls');
      var panel = document.getElementById(targetId);
      if (panel) panel.hidden = false;

      if (focus) tabs[index].focus();
    }

    tabs.forEach(function (tab, i) {
      tab.addEventListener('click', function () { activate(i, false); });

      tab.addEventListener('keydown', function (e) {
        var key = e.key;
        var lastIndex = tabs.length - 1;
        var nextIndex;

        if (key === 'ArrowRight' || key === 'ArrowDown') {
          nextIndex = i === lastIndex ? 0 : i + 1;
        } else if (key === 'ArrowLeft' || key === 'ArrowUp') {
          nextIndex = i === 0 ? lastIndex : i - 1;
        } else if (key === 'Home') {
          nextIndex = 0;
        } else if (key === 'End') {
          nextIndex = lastIndex;
        } else {
          return;
        }
        e.preventDefault();
        activate(nextIndex, true);
      });
    });
  });
</script>

