</style>

<div class="custom-tabs">
  <div class="page-width">
    {% if section.settings['r-title'] != blank %}
      <div class="custom-tabs-title">
        {{ section.settings['r-title'] }}
      </div>
    {% endif %}
  
    <div class="custom-tabs-wrapper">
      <!-- Tab Navigation -->
      <!-- Tab Navigation -->
<div class="custom-tabs-wrapper-ingredients-wrapper">
  {% assign first_tab_rendered = false %}
  {% for block in section.blocks %}
    {% if block.type == 'tab-heading-block' %}
      {% assign tab_id = block.settings['t-ingredient-id'] %}
      <div
        class="custom-tabs-wrapper-ingredients-wrapper-item {% unless first_tab_rendered %}active{% endunless %}"
        data-id="tab-{{ tab_id }}"
      >
        {% if block.settings.tab_cc_icon != blank %}
          <div class="tab-cc-icon">
            {{ block.settings.tab_cc_icon | image_url: width: 1440 | image_tag:
              widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
              class:'',
              alt: "icon",
              loading: "eager"
            }}
          </div>
        {% endif %}
        {% if block.settings['r-ingredient-name'] != blank %}
          <span class="name">{{ block.settings['r-ingredient-name'] }}</span>
        {% endif %}
      </div>
      {% assign first_tab_rendered = true %}
    {% endif %}
  {% endfor %}
</div>

      <!-- Display Wrapper -->
      <div class="custom-tabs-wrapper-display-wrapper">
        {% assign tab_ids = "" %}
        {% for block in section.blocks %}
          {% if block.type == 'tab-heading-block' %}
            {% assign tab_id = block.settings['t-ingredient-id'] %}
            {% unless tab_ids contains tab_id %}
              {% assign tab_ids = tab_ids | append: tab_id | append: "," %}
            {% endunless %}
          {% endif %}
        {% endfor %}
        {% assign tab_array = tab_ids | split: "," %}
        {% assign firstTab = true %}
        {% for tab_id in tab_array %}
          {% if tab_id != blank %}
            {% assign is_process_tab = false %}
            {% assign has_stats = false %}
            
            {% for block in section.blocks %}
              {% if block.type == 'process-card-block' and block.settings['process-tab-id'] == tab_id %}
                {% assign is_process_tab = true %}
              {% endif %}
              {% if block.type == 'stats-block' and block.settings['stats-tab-id'] == tab_id %}
                {% assign has_stats = true %}
              {% endif %}
            {% endfor %}

            <!-- Unified container for each tab -->
            <div class="{% if is_process_tab %}process-cards-grid{% else %}product-cards-grid{% endif %} {% if firstTab %}active{% endif %}" data-content="tab-{{ tab_id }}">
              {% assign firstTab = false %}

              <!-- Tab Heading (if exists) -->
              {% for block in section.blocks %}
                {% if block.type == 'tab_heading_content' and block.settings.heading_tab_id == tab_id %}
                  <div class="tab-inner-heading">
                    {% if block.settings.heading_title != blank %}
                      <h2 class="tab-inner-heading-title">{{ block.settings.heading_title }}</h2>
                    {% endif %}
                    {% if block.settings.heading_desc != blank %}
                      <div class="tab-inner-heading-desc">{{ block.settings.heading_desc }}</div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}

              <!-- Cards Grid -->
              <div class="cards-grid-inner">
                {% if is_process_tab %}
                  <!-- Process Cards -->
                  {% for block in section.blocks %}
                    {% if block.type == 'process-card-block' and block.settings['process-tab-id'] == tab_id %}
                      <div class="process-card">
                        {% if block.settings['process-icon'] != blank %}
                          <div class="process-icon">
                                {{ block.settings.process-icon | image_url: width: 1440 | image_tag:
                                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                  class:'',
                                  alt: "image",
                                  loading: "eager"
                                }}
                          </div>
                        {% endif %}
                        <div class="pd_card_wrap">
                        {% if block.settings['process-step'] != blank %}
                          <span class="process-step">{{ block.settings['process-step'] }}</span>
                        {% endif %}
                        {% if block.settings['process-title'] != blank %}
                          <h3 class="process-title">{{ block.settings['process-title'] }}</h3>
                        {% endif %}
                        {% if block.settings['process-desc'] != blank %}
                          <p class="process-desc">{{ block.settings['process-desc'] }}</p>
                        {% endif %}
                      </div>
                      </div>
                    {% endif %}
                  {% endfor %}
                {% else %}
                  <!-- Product Cards -->
                  {% for block in section.blocks %}
                    {% if block.type == 'product-card-block' and block.settings['card-tab-id'] == tab_id %}
                      <div class="product-card">
                        {% if block.settings['card-image'] != blank %}
                          <div class="product-card-image">
                            {{ block.settings.card-image | image_url: width: 1440 | image_tag:
                                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                  class:'',
                                  alt: "image",
                                  loading: "eager"
                                }}
                          </div>
                        {% endif %}
                        <div class="product-card-content">
                          {% if block.settings['card-title'] != blank %}
                            <h3 class="product-card-title">{{ block.settings['card-title'] }}</h3>
                          {% endif %}
                          <div class="product-card-features">
                            {% if block.settings['feature-look'] != blank %}
                              <div class="feature-item">
                                <div class="feature-content">
                                  {% if block.settings['icon-look'] != blank %}
                                    <div class="feature-icon">
                                      {{ block.settings.icon-look | image_url: width: 1440 | image_tag:
                                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                  class:'',
                                  alt: "image",
                                  loading: "eager"
                                }}
                                    </div>
                                  {% endif %}
                                  <div class="feature-label">Look</div>
                                </div>
                                <p class="feature-text">{{ block.settings['feature-look'] }}</p>
                              </div>
                            {% endif %}
                            {% if block.settings['feature-feel'] != blank %}
                              <div class="feature-item">
                                <div class="feature-content">
                                  {% if block.settings['icon-feel'] != blank %}
                                      <div class="feature-icon">
                                      {{ block.settings.icon-feel | image_url: width: 1440 | image_tag:
                                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                  class:'',
                                  alt: "image",
                                  loading: "eager"
                                }}
                                    </div>
                                  {% endif %}
                                  <div class="feature-label">Feel</div>
                                </div>
                                <p class="feature-text">{{ block.settings['feature-feel'] }}</p>
                              </div>
                            {% endif %}
                            {% if block.settings['feature-fabric'] != blank %}
                              <div class="feature-item">
                                <div class="feature-content">
                                  {% if block.settings['icon-fabric'] != blank %}
                                      <div class="feature-icon">
                                      {{ block.settings.icon-fabric | image_url: width: 1440 | image_tag:
                                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                  class:'',
                                  alt: "image",
                                  loading: "eager"
                                }}
                                    </div>
                                  {% endif %}
                                  <div class="feature-label">Fabric Content</div>
                                </div>
                                <p class="feature-text">{{ block.settings['feature-fabric'] }}</p>
                              </div>
                            {% endif %}
                            {% if block.settings['feature-performance'] != blank %}
                              <div class="feature-item">
                                <div class="feature-content">
                                  {% if block.settings['icon-performance'] != blank %}
                                      <div class="feature-icon">
                                      {{ block.settings.icon-performance | image_url: width: 1440 | image_tag:
                                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                  class:'',
                                  alt: "image",
                                  loading: "eager"
                                }}
                                    </div>
                                  {% endif %}
                                  <div class="feature-label">Performance</div>
                                </div>
                                <p class="feature-text">{{ block.settings['feature-performance'] }}</p>
                              </div>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>

              {% comment %} Mobile {% endcomment %}
              {% comment %} <div class="cards-grid-inner-mbl">
                {% if is_process_tab %}
                  <!-- Mobile Process Cards -->
                  {% for block in section.blocks %}
                    {% if block.type == 'process-card-block-mbl' and block.settings['process-tab-id'] == tab_id %}
                      <div class="process-card-mbl">
                        {% if block.settings['process-icon'] != blank %}
                          <div class="process-icon">
                                {{ block.settings.process-icon | image_url: width: 1440 | image_tag:
                                  widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                                  class:'',
                                  alt: "image",
                                  loading: "eager"
                                }}
                          </div>
                        {% endif %}
                      <div class="pd-card-wrap-mbl">
                        {% if block.settings['process-step'] != blank %}
                          <span class="process-step">{{ block.settings['process-step'] }}</span>
                        {% endif %}
                        {% if block.settings['process-title'] != blank %}
                          <h3 class="process-title">{{ block.settings['process-title'] }}</h3>
                        {% endif %}
                        {% if block.settings['process-desc'] != blank %}
                          <p class="process-desc">{{ block.settings['process-desc'] }}</p>
                        {% endif %}
                      </div>
                      </div>
                    {% endif %}
                  {% endfor %}
                {% else %}
                  
                {% endif %}
              </div> {% endcomment %}

              <!-- Stats Block (shown only in the tab it belongs to) -->
              {% if has_stats %}
                <div class="stats-grid">
                  <div class="stat-head">{{ section.settings.stat-head }}</div>
                  <div class="stat-block-wrap">
                  {% for block in section.blocks %}
                    {% if block.type == 'stats-block' and block.settings['stats-tab-id'] == tab_id %}
                      <div class="stat-item">
                        <span class="stat-percentage">{{ block.settings['stat-percentage'] }}</span>
                        <p class="stat-description">{{ block.settings['stat-description'] }}</p>
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const tabItems = document.querySelectorAll('.custom-tabs-wrapper-ingredients-wrapper-item');
    const contentItems = document.querySelectorAll('[data-content]');
  
    tabItems.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-id');
      
        tabItems.forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
      
        contentItems.forEach((content) => content.classList.remove('active'));
      
        const targetContent = document.querySelector(`[data-content="${targetId}"]`);
        if (targetContent) {
          targetContent.classList.add('active');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Coffee Thread Tabs",
  "settings": [
    {
      "type": "richtext",
      "id": "r-title",
      "label": "Section Title",
      "default": "<p>THE COFFEETHREAD™ PROCESS</p>"
    },
    {
      "type": "text",
      "id": "stat-head",
      "label": "Stat Block Heading"
    }
  ],
  "blocks": [
