    }
    .custom-tabs .product-card-mbl{
    width: 100%;
    max-width: 100%;
    min-width: 90%;
    }
    .cards-grid-inner{
    {% comment %} display:none !important; {% endcomment %}
    }
    .cards-grid-inner-mbl {
