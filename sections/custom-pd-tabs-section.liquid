    max-width: 100%;
    min-width: 80%;
    }
    .custom-tabs .process-icon img{
        max-width: 38px;
    max-height: 38px;
    min-height: 38px;
    min-width: 38px;
    }
    .pd_card_wrap{
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    }
    .custom-tabs .stat-head{
