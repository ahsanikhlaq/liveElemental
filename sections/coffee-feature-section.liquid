  "blocks": [
    {
      "type": "left-block",
      "name": "Left Block",
      "settings": [
        {
          "type": "html",
          "id": "i-svg",
          "label": "SVG Icon"
        },
        {
          "type": "image_picker",
          "id": "ingri-img",
          "label": "Image"
        },
        {
          "type": "richtext",
          "id": "i-heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "i-des",
          "label": "Description"
        }
      ]
    },
    {
      "type": "right-block",
      "name": "Right Block",
      "settings": [
        {
          "type": "html",
          "id": "i-svgr",
          "label": "SVG Icon"
        },
        {
          "type": "image_picker",
          "id": "ingri-img-r",
          "label": "Image"
        },
        {
          "type": "richtext",
          "id": "i-headingr",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "i-desr",
          "label": "Description"
        }
      ]
    },
    {
      "type": "mobile-block",
      "name": "Mobile Block",
      "settings": [
        {
          "type": "text",
          "id": "b-count",
          "label": "Count"
        },
        {
          "type": "image_picker",
          "id": "cb-b-icon",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "cb_head",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "cb_desc",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coffee Features Section"
    }
  ]
}
{% endschema %}