<style>
  /* ---------------collapse-css----------------------- */
  .collapsable-tab-content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s ease, opacity 0.4s ease, padding-top 0.4s ease;
    width: 100%;
    padding-left: 0px;
    padding-top: 0;
  }

  .collapsable-tab-content.open {
    opacity: 1;
    padding-top: 18px;
  }
  
  .collapsable-tab-heading {
    margin: 0;
    color: var(--Black, #171717);
    font-family: Quicksand;
    font-size: 16px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
  }
  
  .collapsable-tab-top {
    display: flex;
    justify-content: space-between;
    width: 100%;
    background: transparent;
    border: 0;
    padding: 0;
    text-align: left;
    cursor: pointer;
    color: inherit;
    font: inherit;
  }

  .collapsable-tab-top:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
  
  .collapsable-tab-main {
    padding: 20px 10px;
    border-top: 1px solid #D9D9D9;
    border-bottom: 1px solid #D9D9D9;
    cursor: pointer;
  }
  
  .collapsable-tab-main.first-tab {
    margin-top: 14px;
  }
  
  .collapsable-tab-content p {
    color: var(--Black, #171717);
    font-family: Quicksand;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 20px;
    margin: 0;
  }
</style>

{%- assign panel_id = 'collapsable-tab-' | append: block.id -%}
<div class="collapsable-tab-main" {{ block.shopify_attributes }}>
  <button
    type="button"
    class="collapsable-tab-top"
    aria-expanded="false"
    aria-controls="{{ panel_id }}"
  >
    <h4 class="collapsable-tab-heading">{{ block.settings.heading }}</h4>
    <span aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon-plus" width="16" height="16" viewBox="0 0 16 16" fill="none" focusable="false">
        <path d="M12.9497 7.5H3.05029" stroke="black" stroke-width="2" stroke-linecap="square"/>
        <path d="M8 2.55029V12.4498" stroke="black" stroke-width="2" stroke-linecap="square"/>
      </svg>
    </span>
  </button>
  <div class="collapsable-tab-content" id="{{ panel_id }}" role="region">
    {{ block.settings.content }}
  </div>
</div>

<script>
  (function() {
    // Use a unique approach that works even if script runs multiple times
    const initAccordion = () => {
      const faqItems = document.querySelectorAll('.collapsable-tab-main:not(.accordion-initialized)');
      
      if (faqItems.length === 0) return;

      // Add class to first and last FAQ items (only once)
      const allTabs = document.querySelectorAll('.collapsable-tab-main');
      const firstTab = allTabs[0];
      const lastTab = allTabs[allTabs.length - 1];
      if (firstTab && !firstTab.classList.contains('first-tab')) {
        firstTab.classList.add('first-tab');
      }
      if (lastTab && !lastTab.classList.contains('last-tab')) {
        lastTab.classList.add('last-tab');
      }

      faqItems.forEach((item) => {
        // Mark as initialized to prevent duplicate listeners
        item.classList.add('accordion-initialized');

        item.addEventListener('click', function(e) {
          const answer = this.querySelector('.collapsable-tab-content');
          const icon = this.querySelector('.icon-plus');
          const trigger = this.querySelector('.collapsable-tab-top');
          const isOpen = answer.classList.contains('open');
          // WCAG 4.1.2 — sync ARIA state with visual state.
          if (trigger) trigger.setAttribute('aria-expanded', String(!isOpen));

          // Close all other open tabs
          document.querySelectorAll('.collapsable-tab-content.open').forEach((openAnswer) => {
            if (openAnswer !== answer) {
              openAnswer.style.maxHeight = openAnswer.scrollHeight + 'px';
              requestAnimationFrame(() => {
                openAnswer.style.maxHeight = '0px';
                openAnswer.style.opacity = '0';
              });

              openAnswer.addEventListener('transitionend', function handler(e) {
                if (e.propertyName === 'max-height') {
                  openAnswer.classList.remove('open');
                  openAnswer.closest('.collapsable-tab-main').classList.remove('open');
                  openAnswer.style.maxHeight = '';
                  openAnswer.removeEventListener('transitionend', handler);
                }
              });

              const openIcon = openAnswer.closest('.collapsable-tab-main').querySelector('.icon-plus');
              if (openIcon) {
                openIcon.innerHTML = `
                  <path d="M12.9497 7.5H3.05029" stroke="black" stroke-width="2" stroke-linecap="square"/>
                  <path d="M8 2.55029V12.4498" stroke="black" stroke-width="2" stroke-linecap="square"/>
                `;
              }
            }
          });

          // Toggle current item
          if (!isOpen) {
            answer.classList.add('open');
            this.classList.add('open');
            answer.style.maxHeight = answer.scrollHeight + 'px';
            answer.style.opacity = '1';

            icon.innerHTML = `
              <path d="M10.8995 1H1" stroke="black" stroke-width="2" stroke-linecap="square"/>
            `;

            answer.addEventListener('transitionend', function handler(e) {
              if (e.propertyName === 'max-height') {
                answer.style.maxHeight = 'none';
                answer.removeEventListener('transitionend', handler);
              }
            });
          } else {
            answer.style.maxHeight = answer.scrollHeight + 'px';
            requestAnimationFrame(() => {
              answer.style.maxHeight = '0px';
              answer.style.opacity = '0';
            });

            answer.addEventListener('transitionend', function handler(e) {
              if (e.propertyName === 'max-height') {
                answer.classList.remove('open');
                this.classList.remove('open');
                answer.style.maxHeight = '';
                answer.removeEventListener('transitionend', handler);
              }
            }.bind(this));

            icon.innerHTML = `
              <path d="M12.9497 7.5H3.05029" stroke="black" stroke-width="2" stroke-linecap="square"/>
              <path d="M8 2.55029V12.4498" stroke="black" stroke-width="2" stroke-linecap="square"/>
            `;
          }
        });
      });
    };

    // Initialize on DOM ready and on Shopify editor events
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAccordion);
    } else {
      initAccordion();
    }

    // Reinitialize when blocks are added/removed in Shopify theme editor
    if (typeof Shopify !== 'undefined' && Shopify.designMode) {
      document.addEventListener('shopify:section:load', initAccordion);
      document.addEventListener('shopify:block:select', initAccordion);
    }
  })();
</script>