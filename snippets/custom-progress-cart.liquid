<style>
  .free-shipping-icon {
    display: flex;
    width: 36px;
    height: 36px;
    padding: 8px;
    align-items: center;
    gap: 10px;
    border-radius: 18px;
    background: var(--gold, #AB8D3F);
  }
  
  .cart-container {
    position: relative;
    padding:0 20px;
  }
  
  .cart-body p {
    color: #171717;
{% comment %} text-align: center; {% endcomment %}
font-family: "League Spartan";
font-size: 20px;
font-style: normal;
font-weight: 400;
line-height: 28px; /* 140% */
  }
  
  .cart-body p strong {
    color: var(--Black, #171717);
font-family: "League Spartan";
font-size: 20px;
font-style: normal;
font-weight: 700;
line-height: 28px;
    text-transform: uppercase;
  }
  
  .progress-wrapper {
    position: relative;
    margin-top: 15px;
    margin-bottom: 30px;
  }
  
  .progress-container {
    background-color: #EBEBEB;
    border-radius: 0px;
    height: 8px;
    width: 100%;
    position: relative;
    margin-top: 10px;
  }
  
  .progress-bar {
    background-color: #8C7A6E;
    height: 100%;
    border-radius: 0px;
    width: 0%;
    transition: width 0.5s ease;
  }
  
  .shipping-icon-wrapper {
    position: absolute;
    top: -15px;
    right: -15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    z-index: 10;
  }
  
  .shipping-icon-wrapper .free-shipping-icon {
    width: 36px;
    height: 36px;
    padding: 8px;
    background: #8C7A6E;
  }
  
  .shipping-label {
    display: none;
  }
  
  .gift-icon-wrapper {
    display: none;
  }
  
  .free-shipping-icon svg {
    display: block;
  }
</style>

<div class="cart-container">
  {% if cart.item_count > 0 %}
    <div class="cart-body">
      <p>You are <span class="amount">$0.00</span> away from getting <strong>FREE SHIPPING</strong></p>
      
      <div class="progress-wrapper">
        <div class="progress-container">
          <div class="progress-bar">&nbsp;</div>
          
          <div class="shipping-icon-wrapper">
            <div class="free-shipping-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" fill="none">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M15.6836 4.12958C17.591 4.57219 18.3206 5.68753 19.2354 7.22266H15.6836V4.12958ZM4.53656 7.35156C4.91002 7.35156 5.18109 7.53183 5.18109 7.95312C5.18109 8.30846 4.89357 8.59665 4.53841 8.59766H0.644531C0.288528 8.59766 0 8.88635 0 9.24219C0 9.59819 0.288528 9.88672 0.644531 9.88672H6.44531C6.80467 9.88672 7.09236 10.1751 7.09236 10.5312C7.09236 10.8873 6.80383 11.1758 6.44783 11.1758H0.644531C0.288528 11.1758 0 11.4643 0 11.8203C0 12.1763 0.288528 12.4648 0.644531 12.4648H2.0625V14.3984C2.0625 14.7544 2.35103 15.043 2.70703 15.043H4.00264C4.2336 16.1806 5.23883 17.0195 6.42383 17.0195C7.60883 17.0195 8.61406 16.1806 8.84502 15.043H15.3894C15.6203 16.1806 16.6255 17.0195 17.8105 17.0195C18.9955 17.0195 20.0008 16.1806 20.2317 15.043H21.3555C21.7115 15.043 22 14.7544 22 14.3984V10.5312C22 8.64012 20.0053 8.51457 20.0035 8.51172H15.0391C14.6831 8.51172 14.3945 8.22319 14.3945 7.86719V4H2.70703C2.35103 4 2.0625 4.28853 2.0625 4.64453V6.0625H1.28906C0.93306 6.0625 0.644531 6.35103 0.644531 6.70703C0.644531 7.06303 0.93306 7.35156 1.28906 7.35156H4.53656ZM18.6461 13.7133C19.1075 14.1747 19.1075 14.9231 18.6461 15.3845C17.9039 16.1268 16.6289 15.5987 16.6289 14.5488C16.6289 13.4991 17.9039 12.9711 18.6461 13.7133ZM7.25937 13.7133C7.72078 14.1747 7.72078 14.9231 7.25937 15.3845C6.51715 16.1268 5.24219 15.5987 5.24219 14.5488C5.24219 13.4991 6.51715 12.9711 7.25937 13.7133Z" fill="white"/>
                </svg>
            </div>
            <span class="shipping-label">Free Shipping</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<script>
  (() => {
    const FREE_SHIPPING_THRESHOLD_CENTS = {{ settings.free_shipping_threshold_dollars | default: 200 }} * 100;
    const CONTAINER_SELECTOR = '.cart-body';

    const $ = (sel, root = document) => root.querySelector(sel);

    function getEls() {
      const root = $(CONTAINER_SELECTOR) || document;
      return {
        bar: $('.progress-bar', root),
        msgP: $('p', root),
        amountSpan: $('.amount', root),
      };
    }

    function animateWidth(el, toPct) {
      if (!el) return;
      el.style.width = toPct + '%';
    }

    function updateCartProgress(totalCents) {
      const { bar, msgP, amountSpan } = getEls();
      if (!bar || !msgP) return;

      const remaining = Math.max(FREE_SHIPPING_THRESHOLD_CENTS - totalCents, 0);
      const pct = Math.min((totalCents / FREE_SHIPPING_THRESHOLD_CENTS) * 100, 100);

      animateWidth(bar, pct);

      if (remaining > 0) {
        const txt = (remaining / 100).toFixed(2);
        if (amountSpan) amountSpan.textContent = '$' + txt;
        msgP.innerHTML = `You are <span class="amount">$${txt}</span> away from getting <strong>FREE SHIPPING</strong>`;
      } else {
        msgP.innerHTML = '<strong>Free Shipping</strong> Unlocked!';
      }
    }

    async function fetchCartTotal() {
      try {
        const res = await fetch('/cart.js', { credentials: 'same-origin' });
        const cart = await res.json();
        updateCartProgress(cart.total_price || 0);
      } catch (e) {
        console.error('Cart fetch failed:', e);
      }
    }

    let refreshTimer;
    function refreshDebounced(delay = 100) {
      clearTimeout(refreshTimer);
      refreshTimer = setTimeout(fetchCartTotal, delay);
    }

    ['cart:updated', 'cart:refresh', 'ajaxCart:updated', 'cart:change', 'line-item:change'].forEach((evt) =>
      document.addEventListener(evt, () => refreshDebounced(50))
    );

    document.addEventListener('submit', (e) => {
      if (e.target.matches('form[action*="/cart/add"]')) {
        setTimeout(() => refreshDebounced(150), 300);
      }
    });

    document.addEventListener('change', (e) => {
      if (e.target.matches('input[name="updates[]"], .quantity__input, .cart-quantity, [data-quantity-input]')) {
        refreshDebounced(80);
      }
    });

    const mo = new MutationObserver(() => refreshDebounced(50));
    mo.observe(document.documentElement, { childList: true, subtree: true });

    const _fetch = window.fetch;
    window.fetch = async function (input, init) {
      const p = _fetch.apply(this, arguments);
      try {
        const url = typeof input === 'string' ? input : input?.url || '';
        if (/\/cart\/(add|change|update|clear)\.js|\/cart\.js/.test(url)) {
          p.finally(() => refreshDebounced(80));
        }
      } catch (_) {}
      return p;
    };

    setInterval(() => refreshDebounced(400), 4000);
    document.addEventListener('DOMContentLoaded', () => refreshDebounced(10));
  })();
</script>