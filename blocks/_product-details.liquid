<script>
  (function() {
  'use strict';
  
  function normalizeText(text) {
    // Remove spaces, hyphens, underscores and convert to lowercase
    return text.toLowerCase().replace(/[\s\-_]+/g, '');
  }
  
  function filterImages() {
    // ONLY RUN ON DESKTOP
    if (window.innerWidth <= 768) {
      console.log('⏭️ Desktop filter skipped - Mobile view');
      return;
    }
    
    // Get checked radio
    const checkedRadio = document.querySelector('input[type="radio"][name*="Color"]:checked');
    
    if (!checkedRadio) return;
    
    const selectedColor = checkedRadio.value.trim();
    console.log('🖥️ Desktop - Selected:', selectedColor);
    
    // Normalize selected color
    const normalizedSelected = normalizeText(selectedColor);
    
    // Get all media containers (both grid and slideshow)
    const mediaItems = document.querySelectorAll('.product-media-container, slideshow-slide');
    
    mediaItems.forEach(item => {
      const img = item.querySelector('img');
      
      if (img) {
        const altText = img.getAttribute('alt') || '';
        const srcText = img.getAttribute('src') || '';
        
        // Hide if alt text is "thumbnail"
        if (altText.toLowerCase() === 'thumbnail') {
          item.style.setProperty('display', 'none', 'important');
          item.setAttribute('aria-hidden', 'true');
          return;
        }
        
        // Normalize alt and src
        const normalizedAlt = normalizeText(altText);
        const normalizedSrc = normalizeText(srcText);
        
        // Check if selected color matches alt or src (flexible matching)
        const isMatch = normalizedAlt.includes(normalizedSelected) || 
                        normalizedSrc.includes(normalizedSelected) ||
                        normalizedSelected.includes(normalizedAlt.substring(0, 5)) ||
                        altText === selectedColor;
        
        if (isMatch) {
          item.style.setProperty('display', '', 'important');
          item.removeAttribute('aria-hidden');
        } else {
          item.style.setProperty('display', 'none', 'important');
          item.setAttribute('aria-hidden', 'true');
        }
      }
    });
  }
  
  function filterMobileSlideshow() {
    // ONLY RUN ON MOBILE
    if (window.innerWidth > 768) {
      console.log('⏭️ Mobile filter skipped - Desktop view');
      return;
    }
    
    // Get checked radio
    const checkedRadio = document.querySelector('input[type="radio"][name*="Color"]:checked');
    
    if (!checkedRadio) return;
    
    const selectedColor = checkedRadio.value.trim();
    console.log('📱 Mobile - Selected:', selectedColor);
    
    // Normalize selected color
    const normalizedSelected = normalizeText(selectedColor);
    
    // Get all slideshow slides
    const slides = document.querySelectorAll('slideshow-slide');
    
    slides.forEach(slide => {
      const img = slide.querySelector('img');
      
      if (img) {
        const altText = img.getAttribute('alt') || '';
        const srcText = img.getAttribute('src') || '';
        
        // Hide if alt text is "thumbnail"
        if (altText.toLowerCase() === 'thumbnail') {
          slide.style.setProperty('display', 'none', 'important');
          slide.setAttribute('aria-hidden', 'true');
          return;
        }
        
        // Normalize alt and src
        const normalizedAlt = normalizeText(altText);
        const normalizedSrc = normalizeText(srcText);
        
        // Check if selected color matches alt or src (flexible matching)
        const isMatch = normalizedAlt.includes(normalizedSelected) || 
                        normalizedSrc.includes(normalizedSelected) ||
                        normalizedSelected.includes(normalizedAlt.substring(0, 5)) ||
                        altText === selectedColor;
        
        if (isMatch) {
          slide.style.setProperty('display', '', 'important');
          slide.setAttribute('aria-hidden', 'false');
        } else {
          slide.style.setProperty('display', 'none', 'important');
          slide.setAttribute('aria-hidden', 'true');
        }
      }
    });
    
    // Recalculate slideshow after filtering
    const slideshowComponent = document.querySelector('slideshow-component');
    if (slideshowComponent && slideshowComponent.update) {
      slideshowComponent.update();
    }
  }
  
  function handleFilter() {
    if (window.innerWidth <= 768) {
      filterMobileSlideshow();
    } else {
      filterImages();
    }
  }
  
  // Initialize
  function init() {
    console.log('🎯 Filter initialization...');
    
    const colorRadios = document.querySelectorAll('input[type="radio"][name*="Color"]');
    
    colorRadios.forEach(radio => {
      radio.addEventListener('change', function() {
        requestAnimationFrame(handleFilter);
      });
    });
    
    // Initial filter
    requestAnimationFrame(handleFilter);
    
    // Keep re-applying every 200ms to override any resets
    setInterval(handleFilter, 200);
    
    // Re-run on window resize (in case user switches orientation)
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(handleFilter, 250);
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  
})();
</script>